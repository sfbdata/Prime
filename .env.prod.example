# ===========================================
# BANCO DE DADOS
# ===========================================
POSTGRES_USER=symfony
POSTGRES_PASSWORD=troque_para_senha_forte
POSTGRES_DB=saas
DATABASE_URL=pgsql://symfony:troque_para_senha_forte@db:5432/saas

# ===========================================
# SYMFONY
# ===========================================
# Gere com: php bin/console security:generate-secret
APP_SECRET=troque_para_secret_forte_32_chars

# ===========================================
# MAILER
# ===========================================
# Exemplo Gmail:
# MAILER_DSN=smtp://usuario%40gmail.com:senha_app@smtp.gmail.com:587?encryption=tls&auth_mode=login
# Exemplo SMTP genérico:
# MAILER_DSN=smtp://usuario:senha@smtp.seuservidor.com:587?encryption=tls&auth_mode=login
MAILER_DSN=smtp://usuario:senha@smtp.seuservidor.com:587?encryption=tls&auth_mode=login

# ===========================================
# DATAJUD
# ===========================================
DATAJUD_API_KEY=sua_chave_aqui
DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br

# ===========================================
# APLICAÇÃO
# ===========================================
TZ=America/Sao_Paulo

# URL base da aplicação (usado para gerar links em e-mails)
# Sem TLS: http://IP_DO_SERVIDOR
# Com TLS: https://seudominio.com
DEFAULT_URI=http://IP_DO_SERVIDOR

# Descomente se usar proxy reverso ou TLS
# SYMFONY_TRUSTED_PROXIES=private_ranges
# SYMFONY_TRUSTED_HOSTS=^IP_DO_SERVIDOR$
