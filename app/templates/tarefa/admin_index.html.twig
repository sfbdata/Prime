{% extends 'base.html.twig' %}

{% block title %}Gestão de Tarefas{% endblock %}

{% block body %}
<section class="content-header">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <h1 class="m-0">Gestão de Tarefas</h1>
        <a href="{{ path('tarefa_new') }}" class="btn btn-success">
            <i class="bi bi-plus-lg me-1"></i> Nova Tarefa
        </a>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-body table-responsive p-0">
                {% if tarefas|length > 0 %}
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th><i class="bi bi-card-heading me-1"></i> Título</th>
                            <th><i class="bi bi-flag me-1"></i> Status</th>
                            <th><i class="bi bi-calendar-event me-1"></i> Prazo</th>
                            <th><i class="bi bi-briefcase me-1"></i> Processo</th>
                            <th><i class="bi bi-people me-1"></i> Atribuições</th>
                            <th><i class="bi bi-gear me-1"></i> Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for tarefa in tarefas %}
                        <tr>
                            <td>{{ tarefa.titulo }}</td>
                            <td>
                                <span class="badge {% if tarefa.status == 'concluida' %}text-bg-success{% elseif tarefa.status == 'em_revisao' %}text-bg-warning{% elseif tarefa.status == 'reaberta' %}text-bg-danger{% else %}text-bg-secondary{% endif %}">
                                    {{ tarefa.status|replace({'_': ' '})|upper }}
                                </span>
                            </td>
                            <td>
                                {% set prazoInfo = tarefa.prazoInfo %}
                                {% if prazoInfo.dias is not null %}
                                    <span class="badge text-bg-{{ prazoInfo.cor }}">
                                        <i class="bi bi-clock me-1"></i>{{ prazoInfo.texto }}
                                    </span>
                                    <small class="text-muted d-block">{{ tarefa.prazo|date('d/m/Y H:i') }}</small>
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if tarefa.processo %}
                                    <a href="{{ path('processo_show', {id: tarefa.processo.id}) }}">{{ tarefa.processo.numeroProcesso }}</a>
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td>
                                {% for atr in tarefa.atribuicoes %}
                                    <div>{{ atr.usuario.fullName }} ({{ atr.status|replace({'_': ' '}) }})</div>
                                {% endfor %}
                            </td>
                            <td>
                                <a href="{{ path('tarefa_show', {id: tarefa.id}) }}" class="btn btn-sm btn-info">Ver</a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
                {% else %}
                <div class="p-3">
                    <div class="alert alert-info mb-0"><i class="bi bi-info-circle me-1"></i> Nenhuma tarefa cadastrada.</div>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</section>
{% endblock %}
