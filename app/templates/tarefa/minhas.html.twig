{% extends 'base.html.twig' %}

{% block title %}Minhas Tarefas{% endblock %}

{% block body %}
<section class="content-header">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <h1 class="m-0">Minhas Tarefas</h1>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-body table-responsive p-0">
                {% if atribuicoes|length > 0 %}
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th><i class="bi bi-card-heading me-1"></i> Título</th>
                            <th><i class="bi bi-flag me-1"></i> Status</th>
                            <th><i class="bi bi-calendar-event me-1"></i> Prazo</th>
                            <th><i class="bi bi-folder me-1"></i> Pasta</th>
                            <th><i class="bi bi-gear me-1"></i> Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for atribuicao in atribuicoes %}
                        {% set tarefa = atribuicao.tarefa %}
                        <tr>
                            <td>{{ tarefa.titulo }}</td>
                            <td>
                                <span class="badge {% if atribuicao.status == 'concluida' %}text-bg-success{% elseif atribuicao.status == 'em_revisao' %}text-bg-warning{% else %}text-bg-secondary{% endif %}">
                                    {{ atribuicao.status|replace({'_': ' '})|upper }}
                                </span>
                            </td>
                            <td>
                                {% set prazoInfo = tarefa.prazoInfo %}
                                {% if prazoInfo.dias is not null %}
                                    <span class="badge text-bg-{{ prazoInfo.cor }}">
                                        <i class="bi bi-clock me-1"></i>{{ prazoInfo.texto }}
                                    </span>
                                    <small class="text-muted d-block">{{ tarefa.prazo|date('d/m/Y H:i') }}</small>
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if tarefa.pasta %}
                                    <a href="{{ path('pasta_show', {id: tarefa.pasta.id}) }}">{{ tarefa.pasta.nup ?? 'Pasta #' ~ tarefa.pasta.id }}</a>
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td>
                                <a href="{{ path('tarefa_show', {id: tarefa.id}) }}"
                                   class="btn-action btn-action-view"
                                   title="Visualizar tarefa"
                                   aria-label="Visualizar tarefa">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
                {% else %}
                <div class="p-3">
                    <div class="alert alert-info mb-0"><i class="bi bi-info-circle me-1"></i> Você não possui tarefas atribuídas.</div>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</section>
{% endblock %}
