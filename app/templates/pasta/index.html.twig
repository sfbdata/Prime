{% extends 'base.html.twig' %}

{% block title %}Pastas{% endblock %}

{% block body %}
<section class="content-header">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <h1 class="m-0"><i class="bi bi-folder2-open me-2"></i>Pastas</h1>
        <a href="{{ path('pasta_new') }}" class="btn btn-success">
            <i class="bi bi-plus-lg me-1"></i> Nova Pasta
        </a>
    </div>
</section>

<section class="content">
    <div class="container-fluid">

        {% if pastas|length > 0 %}
        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-muted">
                <i class="bi bi-list-ul me-1"></i> {{ pastas|length }} pasta(s) encontrada(s)
            </span>
        </div>

        <div class="card">
            <div class="card-body table-responsive p-0">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th><i class="bi bi-upc me-1"></i> NUP</th>
                            <th><i class="bi bi-person me-1"></i> Cliente</th>
                            <th><i class="bi bi-people me-1"></i> Partes</th>
                            <th><i class="bi bi-briefcase me-1"></i> Nome da Ação</th>
                            <th><i class="bi bi-file-earmark-check me-1"></i> Status da Documentação</th>
                            <th><i class="bi bi-flag me-1"></i> Status</th>
                            <th><i class="bi bi-clock-history me-1"></i> Última Modificação</th>
                            <th><i class="bi bi-gear me-1"></i> Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for pasta in pastas %}
                        <tr>
                            <td class="fw-semibold">{{ pasta.nup }}</td>
                            <td>
                                {% if pasta.clientes|length > 0 %}
                                    {% for cliente in pasta.clientes %}
                                        <div>{{ cliente.nomeExibicao }}</div>
                                    {% endfor %}
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if pasta.partesContrarias|length > 0 %}
                                    {% for parte in pasta.partesContrarias %}
                                        <div>{{ parte.nome }}</div>
                                    {% endfor %}
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if pasta.processo %}
                                    {{ pasta.processo.classeProcessual ?: pasta.processo.assuntoProcessual ?: pasta.processo.numeroProcesso }}
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if pasta.statusDocumentos == 'APTO_PARA_PROTOCOLAR' %}
                                    <span class="badge text-bg-success">
                                        <i class="bi bi-check-circle me-1"></i>Apto para Protocolar
                                    </span>
                                {% else %}
                                    <span class="badge text-bg-warning text-dark">
                                        <i class="bi bi-exclamation-circle me-1"></i>Pendente de Documentação
                                    </span>
                                {% endif %}
                            </td>

                            
                            <td>
                                <span class="badge {{ pasta.status == 'ativo' ? 'text-bg-success' : 'text-bg-secondary' }}">
                                    {{ pasta.status == 'ativo' ? 'Ativo' : 'Arquivado' }}
                                </span>
                            </td>


                            <td>
                                {% set dias = date().diff(pasta.dataAbertura).days %}
                                {% if dias == 0 %}
                                    Hoje
                                {% elseif dias == 1 %}
                                    1 dia atrás
                                {% else %}
                                    {{ dias }} dias atrás
                                {% endif %}
                            </td>
                            <td>
                                <div class="acoes-grupo">
                                    <a href="{{ path('pasta_show', {id: pasta.id}) }}"
                                       class="btn-action btn-action-view"
                                       title="Visualizar pasta"
                                       aria-label="Visualizar pasta">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="{{ path('pasta_edit', {id: pasta.id}) }}"
                                       class="btn-action btn-action-edit"
                                       title="Editar pasta"
                                       aria-label="Editar pasta">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" action="{{ path('pasta_delete', {id: pasta.id}) }}"
                                          onsubmit="return confirm('Tem certeza que deseja excluir a pasta {{ pasta.nup|e('js') }}?');" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_pasta_' ~ pasta.id) }}">
                                        <button type="submit"
                                                class="btn-action btn-action-delete"
                                                title="Excluir pasta"
                                                aria-label="Excluir pasta">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% else %}
        <div class="alert alert-info mb-0">
            <i class="bi bi-info-circle me-1"></i>
            Nenhuma pasta cadastrada. <a href="{{ path('pasta_new') }}">Criar nova pasta</a>
        </div>
        {% endif %}

    </div>
</section>
{% endblock %}
