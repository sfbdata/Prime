{% extends 'base.html.twig' %}

{% block title %}Pastas{% endblock %}

{% block body %}
<section class="content-header">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <h1 class="m-0"><i class="bi bi-folder2-open me-2"></i>Pastas</h1>
        <a href="{{ path('pasta_new') }}" class="btn btn-success">
            <i class="bi bi-plus-lg me-1"></i> Nova Pasta
        </a>
    </div>
</section>

<section class="content">
    <div class="container-fluid">

        {% if pastas|length > 0 %}
        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-muted">
                <i class="bi bi-list-ul me-1"></i> {{ pastas|length }} pasta(s) encontrada(s)
            </span>
        </div>

        <div class="card">
            <div class="card-body table-responsive p-0">
                <table class="table table-striped table-hover mb-0" id="tabelaPastas">
                    <thead>
                        <tr>
                            <th class="sortable" data-col="0"><i class="bi bi-upc me-1"></i> NUP <i class="bi bi-arrow-down-up sort-icon"></i></th>
                            <th class="sortable" data-col="1"><i class="bi bi-person me-1"></i> Cliente <i class="bi bi-arrow-down-up sort-icon"></i></th>
                            <th class="sortable" data-col="2"><i class="bi bi-people me-1"></i> Partes Contrárias <i class="bi bi-arrow-down-up sort-icon"></i></th>
                            <th class="sortable" data-col="3"><i class="bi bi-briefcase me-1"></i> Nome da Ação <i class="bi bi-arrow-down-up sort-icon"></i></th>
                            <th class="sortable" data-col="4"><i class="bi bi-file-earmark-check me-1"></i> Documentação <i class="bi bi-arrow-down-up sort-icon"></i></th>
                            <th class="sortable" data-col="5"><i class="bi bi-flag me-1"></i> Status da Pasta <i class="bi bi-arrow-down-up sort-icon"></i></th>
                            <th class="sortable" data-col="6"><i class="bi bi-person-badge me-1"></i> Responsável <i class="bi bi-arrow-down-up sort-icon"></i></th>
                            <th class="sortable" data-col="7"><i class="bi bi-clock-history me-1"></i> Última Modificação <i class="bi bi-arrow-down-up sort-icon"></i></th>
                            <th><i class="bi bi-gear me-1"></i> Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for pasta in pastas %}
                        <tr>
                            <td class="fw-semibold">{{ pasta.nup }}</td>
                            <td>
                                {% if pasta.clientes|length > 0 %}
                                    {% for cliente in pasta.clientes %}
                                        <div>{{ cliente.nomeExibicao }}</div>
                                    {% endfor %}
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if pasta.partesContrarias|length > 0 %}
                                    {% for parte in pasta.partesContrarias %}
                                        <div>{{ parte.nome }}</div>
                                    {% endfor %}
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if pasta.processo %}
                                    {{ pasta.processo.classeProcessual ?: pasta.processo.assuntoProcessual ?: pasta.processo.numeroProcesso }}
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if pasta.statusDocumentos == 'APTO_PARA_PROTOCOLAR' %}
                                    <span class="badge text-bg-success">
                                        <i class="bi bi-check-circle me-1"></i>Apto para Protocolar
                                    </span>
                                {% else %}
                                    <span class="badge text-bg-warning text-dark">
                                        <i class="bi bi-exclamation-circle me-1"></i>Pendente de Documentação
                                    </span>
                                {% endif %}
                            </td>

                            
                            <td>
                                <span class="badge {{ pasta.status == 'ativo' ? 'text-bg-success' : 'text-bg-secondary' }}">
                                    {{ pasta.status == 'ativo' ? 'Ativo' : 'Arquivado' }}
                                </span>
                            </td>


                            <td>
                                {{ pasta.responsavel ? pasta.responsavel.fullName : '—' }}
                            </td>
                            <td>
                                {% set dias = date().diff(pasta.dataAbertura).days %}
                                {% if dias == 0 %}
                                    Hoje
                                {% elseif dias == 1 %}
                                    1 dia atrás
                                {% else %}
                                    {{ dias }} dias atrás
                                {% endif %}
                            </td>
                            <td>
                                <div class="acoes-grupo">
                                    <a href="{{ path('pasta_show', {id: pasta.id}) }}"
                                       class="btn-action btn-action-view"
                                       title="Visualizar pasta"
                                       aria-label="Visualizar pasta">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="{{ path('pasta_edit', {id: pasta.id}) }}"
                                       class="btn-action btn-action-edit"
                                       title="Editar pasta"
                                       aria-label="Editar pasta">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" action="{{ path('pasta_delete', {id: pasta.id}) }}"
                                          onsubmit="return confirm('Tem certeza que deseja excluir a pasta {{ pasta.nup|e('js') }}?');" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_pasta_' ~ pasta.id) }}">
                                        <button type="submit"
                                                class="btn-action btn-action-delete"
                                                title="Excluir pasta"
                                                aria-label="Excluir pasta">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% else %}
        <div class="alert alert-info mb-0">
            <i class="bi bi-info-circle me-1"></i>
            Nenhuma pasta cadastrada. <a href="{{ path('pasta_new') }}">Criar nova pasta</a>
        </div>
        {% endif %}

    </div>
</section>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<style>
.sortable {
    cursor: pointer;
    user-select: none;
    white-space: nowrap;
}
.sortable:hover {
    background-color: rgba(0,0,0,0.05);
}
.sort-icon {
    font-size: 0.7em;
    opacity: 0.4;
    flex-shrink: 0;
}
.sortable.asc .sort-icon,
.sortable.desc .sort-icon {
    opacity: 1;
}
.sortable.asc .sort-icon::before {
    content: "\F148";
}
.sortable.desc .sort-icon::before {
    content: "\F128";
}
</style>
<script>
$(document).ready(function() {
    const table = document.getElementById('tabelaPastas');
    if (!table) return;
    const headers = table.querySelectorAll('th.sortable');
    const tbody = table.querySelector('tbody');

    headers.forEach(header => {
        header.addEventListener('click', function() {
            const col = parseInt(this.dataset.col);
            const isAsc = this.classList.contains('asc');

            headers.forEach(h => h.classList.remove('asc', 'desc'));
            this.classList.add(isAsc ? 'desc' : 'asc');

            const rows = Array.from(tbody.querySelectorAll('tr'));

            rows.sort((a, b) => {
                let aVal = a.cells[col]?.textContent.trim() || '';
                let bVal = b.cells[col]?.textContent.trim() || '';

                aVal = aVal.toLowerCase();
                bVal = bVal.toLowerCase();

                if (isAsc) {
                    return bVal.localeCompare(aVal, 'pt-BR');
                } else {
                    return aVal.localeCompare(bVal, 'pt-BR');
                }
            });

            rows.forEach(row => tbody.appendChild(row));
        });
    });
});
</script>

{{ include('_partials/modal_access_request.html.twig') }}
{% endblock %}
