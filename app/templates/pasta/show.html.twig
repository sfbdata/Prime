{% extends 'base.html.twig' %}

{% block title %}Pasta {{ pasta.nup }}{% endblock %}

{% block body %}
{# Content Header #}
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <i class="bi bi-folder2-open me-2"></i>{{ pasta.nup }}
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-end">
                    <li class="breadcrumb-item"><a href="{{ path('homepage') }}">Home</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('pasta_index') }}">Pastas</a></li>
                    <li class="breadcrumb-item active">Detalhes</li>
                </ol>
            </div>
        </div>
    </div>
</div>

{# Main Content #}
<section class="content">
    <div class="container-fluid">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h3 class="card-title"><i class="bi bi-folder me-1"></i> Pasta</h3>
                <div class="card-tools">
                    <span class="badge {{ pasta.status == 'ativo' ? 'text-bg-success' : 'text-bg-secondary' }}">
                        {{ pasta.status == 'ativo' ? 'Ativo' : 'Arquivado' }}
                    </span>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    {# Left Column - Tabs #}
                    <div class="col-12 col-md-12 col-lg-8 order-2 order-md-1">
                        {# Info Boxes #}
                        <div class="row">
                            <div class="col-12 col-sm-4">
                                <div class="info-box bg-light">
                                    <div class="info-box-content">
                                        <span class="info-box-text text-center text-muted">Status</span>
                                        <span class="info-box-number text-center text-muted mb-0">
                                            {{ pasta.status == 'ativo' ? 'Ativo' : 'Arquivado' }}
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-sm-4">
                                <div class="info-box bg-light">
                                    <div class="info-box-content">
                                        <span class="info-box-text text-center text-muted">Clientes</span>
                                        <span class="info-box-number text-center text-muted mb-0">{{ pasta.clientes|length }}</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-sm-4">
                                <div class="info-box bg-light">
                                    <div class="info-box-content">
                                        <span class="info-box-text text-center text-muted">Documentos</span>
                                        <span class="info-box-number text-center text-muted mb-0">{{ pasta.documentos|length }}</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# Tabs #}
                        <ul class="nav nav-tabs" id="pastaTabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="dados-tab" data-bs-toggle="tab" data-bs-target="#dados" type="button" role="tab" aria-controls="dados" aria-selected="true">
                                    <i class="bi bi-folder me-1"></i> Dados da Pasta
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="documentos-tab" data-bs-toggle="tab" data-bs-target="#documentos" type="button" role="tab" aria-controls="documentos" aria-selected="false">
                                    <i class="bi bi-file-earmark-text me-1"></i> Documentos
                                    <span class="badge text-bg-secondary ms-1">{{ pasta.documentos|length }}</span>
                                </button>
                            </li>
                        </ul>

                        <div class="tab-content mt-3" id="pastaTabsContent">
                            {# Tab: Dados da Pasta #}
                            <div class="tab-pane fade show active" id="dados" role="tabpanel" aria-labelledby="dados-tab">
                                <h5 class="mb-3"><i class="bi bi-info-circle me-1"></i> Informações Gerais</h5>
                                <div class="row mb-4">
                                    <div class="col-md-6">
                                        <div class="text-muted">
                                            <p class="text-sm mb-2">NUP
                                                <b class="d-block">{{ pasta.nup }} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ pasta.nup }}" title="Copiar"></i></b>
                                            </p>
                                            <p class="text-sm mb-2">Data de Abertura
                                                <b class="d-block">{{ pasta.dataAbertura|date('d/m/Y') }} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ pasta.dataAbertura|date('d/m/Y') }}" title="Copiar"></i></b>
                                            </p>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="text-muted">
                                            <p class="text-sm mb-2">Processo Vinculado
                                                <b class="d-block">
                                                    {% if pasta.processo %}
                                                        <a href="{{ path('processo_show', {id: pasta.processo.id}) }}">
                                                            {{ pasta.processo.numeroProcesso }}
                                                        </a>
                                                    {% else %}
                                                        <span class="text-muted">—</span>
                                                    {% endif %}
                                                </b>
                                            </p>
                                            <p class="text-sm mb-2">Criada em
                                                <b class="d-block">{{ pasta.createdAt|date('d/m/Y H:i') }}</b>
                                            </p>
                                        </div>
                                    </div>
                                </div>

                                {% if pasta.descricao %}
                                <h5 class="mb-3"><i class="bi bi-card-text me-1"></i> Descrição</h5>
                                <div class="row mb-4">
                                    <div class="col-12">
                                        <div class="p-3 bg-light rounded" style="white-space: pre-wrap;">{{ pasta.descricao }}</div>
                                    </div>
                                </div>
                                {% endif %}
                            </div>

                            {# Tab: Documentos #}
                            <div class="tab-pane fade" id="documentos" role="tabpanel" aria-labelledby="documentos-tab">
                                {% if pasta.documentos|length > 0 %}
                                <div class="table-responsive mb-4">
                                    <table class="table table-striped table-hover align-middle">
                                        <thead>
                                            <tr>
                                                <th><i class="bi bi-fonts me-1"></i> Título</th>
                                                <th><i class="bi bi-tag me-1"></i> Categoria</th>
                                                <th><i class="bi bi-card-text me-1"></i> Descrição</th>
                                                <th><i class="bi bi-hdd me-1"></i> Tamanho</th>
                                                <th><i class="bi bi-calendar-event me-1"></i> Upload</th>
                                                <th><i class="bi bi-gear me-1"></i> Ações</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for doc in pasta.documentos %}
                                            <tr>
                                                <td>
                                                    <i class="bi bi-file-earmark me-1 text-muted"></i>
                                                    {{ doc.titulo }}
                                                    <small class="text-muted d-block">{{ doc.nomeOriginal }}</small>
                                                </td>
                                                <td>
                                                    {% set categoriaLabel = {
                                                        'peticao': 'Petição',
                                                        'contrato': 'Contrato',
                                                        'procuracao': 'Procuração',
                                                        'sentenca': 'Sentença',
                                                        'outros': 'Outros'
                                                    } %}
                                                    <span class="badge text-bg-light border">
                                                        {{ categoriaLabel[doc.categoria] ?? doc.categoria }}
                                                    </span>
                                                </td>
                                                <td>
                                                    {% if doc.descricao %}
                                                        <span class="text-truncate d-inline-block" style="max-width: 200px;" title="{{ doc.descricao }}">
                                                            {{ doc.descricao }}
                                                        </span>
                                                    {% else %}
                                                        <span class="text-muted">—</span>
                                                    {% endif %}
                                                </td>
                                                <td class="text-nowrap">
                                                    {% if doc.tamanhoBytes < 1024 %}
                                                        {{ doc.tamanhoBytes }} B
                                                    {% elseif doc.tamanhoBytes < 1048576 %}
                                                        {{ (doc.tamanhoBytes / 1024)|round(1) }} KB
                                                    {% else %}
                                                        {{ (doc.tamanhoBytes / 1048576)|round(1) }} MB
                                                    {% endif %}
                                                </td>
                                                <td class="text-nowrap">{{ doc.uploadedAt|date('d/m/Y H:i') }}</td>
                                                <td>
                                                    <div class="d-flex gap-1">
                                                        <a href="{{ path('pasta_documento_download', {id: doc.id}) }}"
                                                           class="btn btn-sm btn-outline-primary" title="Download">
                                                            <i class="bi bi-download"></i>
                                                        </a>
                                                        <form method="post"
                                                              action="{{ path('pasta_documento_delete', {id: doc.id}) }}"
                                                              onsubmit="return confirm('Deseja excluir o documento {{ doc.titulo|e('js') }}?');">
                                                            <input type="hidden" name="_token"
                                                                   value="{{ csrf_token('delete_documento_' ~ doc.id) }}">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Deletar">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                                {% else %}
                                <div class="alert alert-light border mb-4">
                                    <i class="bi bi-info-circle me-1"></i> Nenhum documento enviado ainda.
                                </div>
                                {% endif %}

                                {# Formulário de Upload #}
                                <div class="card bg-light border">
                                    <div class="card-header">
                                        <h5 class="card-title mb-0">
                                            <i class="bi bi-cloud-upload me-1"></i> Enviar Novo Documento
                                        </h5>
                                    </div>
                                    <div class="card-body">
                                        <form method="post"
                                              action="{{ path('pasta_documento_upload', {id: pasta.id}) }}"
                                              enctype="multipart/form-data">
                                            <input type="hidden" name="_token"
                                                   value="{{ csrf_token('upload_documento_' ~ pasta.id) }}">
                                            <div class="row g-3">
                                                <div class="col-md-6">
                                                    <label for="upload_arquivo" class="form-label">
                                                        Arquivo <span class="text-danger">*</span>
                                                    </label>
                                                    <input type="file" id="upload_arquivo" name="arquivo"
                                                           class="form-control" required
                                                           accept=".pdf,.jpg,.jpeg,.png,.mp4,.mpeg">
                                                    <div class="form-text">PDF (10 MB), Imagem JPG/PNG (3 MB), Vídeo MP4/MPEG (50 MB)</div>
                                                </div>
                                                <div class="col-md-6">
                                                    <label for="upload_titulo" class="form-label">Título</label>
                                                    <input type="text" id="upload_titulo" name="titulo"
                                                           class="form-control" placeholder="Deixe em branco para usar o nome do arquivo">
                                                </div>
                                                <div class="col-md-4">
                                                    <label for="upload_categoria" class="form-label">
                                                        Categoria <span class="text-danger">*</span>
                                                    </label>
                                                    <select id="upload_categoria" name="categoria" class="form-select" required>
                                                        <option value="peticao">Petição</option>
                                                        <option value="contrato">Contrato</option>
                                                        <option value="procuracao">Procuração</option>
                                                        <option value="sentenca">Sentença</option>
                                                        <option value="outros" selected>Outros</option>
                                                    </select>
                                                </div>
                                                <div class="col-md-8">
                                                    <label for="upload_descricao" class="form-label">Descrição</label>
                                                    <textarea id="upload_descricao" name="descricao"
                                                              class="form-control" rows="2"
                                                              placeholder="Descrição opcional do documento"></textarea>
                                                </div>
                                                <div class="col-12">
                                                    <button type="submit" class="btn btn-primary">
                                                        <i class="bi bi-upload me-1"></i> Enviar Documento
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    {# Right Column - Sidebar #}
                    <div class="col-12 col-md-12 col-lg-4 order-1 order-md-2">
                        <div class="card card-primary card-outline">
                            <div class="card-header">
                                <h3 class="card-title"><i class="bi bi-link-45deg me-1"></i> Vínculos</h3>
                            </div>
                            <div class="card-body">
                                {# Clientes Vinculados #}
                                <h6 class="text-muted mb-3"><i class="bi bi-people me-1"></i> Clientes</h6>
                                {% if pasta.clientes|length > 0 %}
                                    {% for cliente in pasta.clientes %}
                                        <a href="{{ path('cliente_show', {id: cliente.id}) }}" class="d-block text-decoration-none mb-3 pb-3 border-bottom vinculo-link">
                                            <div class="d-flex align-items-center gap-2">
                                                <i class="bi bi-person-circle text-muted"></i>
                                                <span class="fw-semibold text-primary">
                                                    {% if cliente.cpf is defined and cliente.cpf %}
                                                        {{ cliente.nomeCompleto }}
                                                    {% else %}
                                                        {{ cliente.razaoSocial }}
                                                    {% endif %}
                                                </span>
                                            </div>
                                        </a>
                                    {% endfor %}
                                {% else %}
                                    <p class="text-muted small mb-3"><i class="bi bi-info-circle me-1"></i> Nenhum cliente vinculado.</p>
                                {% endif %}

                                <hr>

                                {# Partes Contrárias #}
                                <h6 class="text-muted mb-3"><i class="bi bi-person-x me-1"></i> Partes Contrárias</h6>
                                {% if pasta.partesContrarias|length > 0 %}
                                    {% for parte in pasta.partesContrarias %}
                                        <div class="d-flex align-items-center gap-2 mb-3 pb-3 border-bottom">
                                            <i class="bi bi-person-dash text-muted"></i>
                                            <span>{{ parte.nome }}</span>
                                        </div>
                                    {% endfor %}
                                {% else %}
                                    <p class="text-muted small mb-0"><i class="bi bi-info-circle me-1"></i> Nenhuma parte contrária registrada.</p>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer">
                <div class="d-flex justify-content-between">
                    <a href="{{ path('pasta_index') }}" class="btn btn-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Voltar às Pastas
                    </a>
                    <div class="d-flex gap-2">
                        <a href="{{ path('pasta_edit', {id: pasta.id}) }}" class="btn btn-warning">
                            <i class="bi bi-pencil me-1"></i> Editar
                        </a>
                        <form method="post" action="{{ path('pasta_delete', {id: pasta.id}) }}"
                              onsubmit="return confirm('Tem certeza que deseja excluir esta pasta? Esta ação não pode ser desfeita.');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_pasta_' ~ pasta.id) }}">
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash me-1"></i> Excluir Pasta
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
.copy-btn {
    cursor: pointer;
    opacity: 0.6;
    font-size: 0.85em;
    transition: opacity 0.2s, color 0.2s;
}
.copy-btn:hover {
    opacity: 1;
}
.copy-btn.copied {
    color: #198754 !important;
}
.vinculo-link {
    transition: background-color 0.2s;
    border-radius: 4px;
    padding: 8px;
    margin-left: -8px;
    margin-right: -8px;
}
.vinculo-link:hover {
    background-color: rgba(0,0,0,0.03);
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.copy-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            const text = this.getAttribute('data-copy');
            navigator.clipboard.writeText(text).then(() => {
                this.classList.remove('bi-copy');
                this.classList.add('bi-check-lg', 'copied');
                setTimeout(() => {
                    this.classList.remove('bi-check-lg', 'copied');
                    this.classList.add('bi-copy');
                }, 1500);
            });
        });
    });
});
</script>
{% endblock %}
