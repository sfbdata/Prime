{% extends 'base.html.twig' %}

{% block title %}Pasta {{ pasta.nup }}{% endblock %}

{% block body %}
{# Content Header #}
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <i class="bi bi-folder2-open me-2"></i>{{ pasta.nup }}
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-end">
                    <li class="breadcrumb-item"><a href="{{ path('homepage') }}">Home</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('pasta_index') }}">Pastas</a></li>
                    <li class="breadcrumb-item active">Detalhes</li>
                </ol>
            </div>
        </div>
    </div>
</div>

{# Main Content #}
<section class="content">
    <div class="container-fluid">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h3 class="card-title"><i class="bi bi-folder me-1"></i> Pasta</h3>
                <div class="card-tools">
                    <span class="badge {{ pasta.status == 'ativo' ? 'text-bg-success' : 'text-bg-secondary' }}">
                        {{ pasta.status == 'ativo' ? 'Ativo' : 'Arquivado' }}
                    </span>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    {# Left Column - Tabs #}
                    <div class="col-12 col-md-12 col-lg-8 order-2 order-md-1">
                        {# Info Boxes #}
                        <div class="row">
                            <div class="col-12 col-sm-6">
                                <div class="info-box bg-light">
                                    <div class="info-box-content">
                                        <span class="info-box-text text-center text-muted">Status</span>
                                        <span class="info-box-number text-center text-muted mb-0">
                                            {{ pasta.status == 'ativo' ? 'Ativo' : 'Arquivado' }}
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6">
                                <div class="info-box bg-light">
                                    <div class="info-box-content">
                                        <span class="info-box-text text-center text-muted">Clientes</span>
                                        <span class="info-box-number text-center text-muted mb-0">{{ pasta.clientes|length }}</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# Tabs #}
                        <ul class="nav nav-tabs" id="pastaTabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="dados-tab" data-bs-toggle="tab" data-bs-target="#dados" type="button" role="tab" aria-controls="dados" aria-selected="true">
                                    <i class="bi bi-folder me-1"></i> Dados da Pasta
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="partes-tab" data-bs-toggle="tab" data-bs-target="#partes" type="button" role="tab" aria-controls="partes" aria-selected="false">
                                    <i class="bi bi-people me-1"></i> Partes
                                    {% set totalPartes = pasta.clientes|length + pasta.partesContrarias|length %}
                                    {% if totalPartes > 0 %}
                                        <span class="badge text-bg-secondary ms-1">{{ totalPartes }}</span>
                                    {% endif %}
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="tarefas-tab" data-bs-toggle="tab" data-bs-target="#tarefas" type="button" role="tab" aria-controls="tarefas" aria-selected="false">
                                    <i class="bi bi-check2-square me-1"></i> Tarefas
                                    {% if pasta.tarefas|length > 0 %}
                                        <span class="badge text-bg-secondary ms-1">{{ pasta.tarefas|length }}</span>
                                    {% endif %}
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="detalhes-tab" data-bs-toggle="tab" data-bs-target="#detalhes" type="button" role="tab" aria-controls="detalhes" aria-selected="false">
                                    <i class="bi bi-info-circle me-1"></i> Detalhes
                                </button>
                            </li>
                        </ul>

                        <div class="tab-content mt-3" id="pastaTabsContent">
                            {# Tab: Dados da Pasta #}
                            <div class="tab-pane fade show active" id="dados" role="tabpanel" aria-labelledby="dados-tab">
                                <h5 class="mb-3"><i class="bi bi-info-circle me-1"></i> Informações Gerais</h5>
                                <div class="row mb-4">
                                    <div class="col-md-6">
                                        <div class="text-muted">
                                            <p class="text-sm mb-2"><abbr title="Número Único de Pasta">NUP</abbr>
                                                <b class="d-block">{{ pasta.nup }} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ pasta.nup }}" title="Copiar"></i></b>
                                            </p>
                                            <p class="text-sm mb-2">Data de Abertura
                                                <b class="d-block">{{ pasta.dataAbertura|date('d/m/Y') }} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ pasta.dataAbertura|date('d/m/Y') }}" title="Copiar"></i></b>
                                            </p>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="text-muted">
                                            <p class="text-sm mb-2">Processo Vinculado
                                                <b class="d-block">
                                                    {% if pasta.processo %}
                                                        <a href="{{ path('processo_show', {id: pasta.processo.id}) }}">
                                                            {{ pasta.processo.numeroProcesso }}
                                                        </a>
                                                    {% else %}
                                                        <span class="text-muted">—</span>
                                                    {% endif %}
                                                </b>
                                            </p>
                                            <p class="text-sm mb-2">Responsável
                                                <b class="d-block">{{ pasta.responsavel ? pasta.responsavel.fullName : '—' }}</b>
                                            </p>
                                        </div>
                                    </div>
                                </div>

                                {% if pasta.descricao %}
                                <hr class="section-divider">

                                <h5 class="mb-3"><i class="bi bi-card-text me-1"></i> Descrição</h5>
                                <div class="row mb-4">
                                    <div class="col-12">
                                        <div class="p-3 bg-light rounded" style="white-space: pre-wrap;">{{ pasta.descricao }}</div>
                                    </div>
                                </div>
                                {% endif %}
                            </div>

                            {# Tab: Partes #}
                            <div class="tab-pane fade" id="partes" role="tabpanel" aria-labelledby="partes-tab">
                                <div class="row">
                                    <div class="col-md-6">
                                        <h5 class="mb-3"><i class="bi bi-people me-1"></i> Clientes</h5>
                                        {% if pasta.clientes|length > 0 %}
                                            {% for cliente in pasta.clientes %}
                                                <a href="{{ path('cliente_show', {id: cliente.id}) }}" class="d-block text-decoration-none mb-3 pb-3 border-bottom vinculo-link">
                                                    <div class="d-flex align-items-center gap-2">
                                                        <i class="bi bi-person-circle text-muted"></i>
                                                        <span class="fw-semibold text-primary">
                                                            {% if cliente.cpf is defined and cliente.cpf %}
                                                                {{ cliente.nomeCompleto }}
                                                            {% else %}
                                                                {{ cliente.razaoSocial }}
                                                            {% endif %}
                                                        </span>
                                                    </div>
                                                </a>
                                            {% endfor %}
                                        {% else %}
                                            <p class="text-muted small mb-3"><i class="bi bi-info-circle me-1"></i> Nenhum cliente vinculado.</p>
                                        {% endif %}
                                    </div>
                                    <div class="col-md-6">
                                        <h5 class="mb-3"><i class="bi bi-person-x me-1"></i> Partes Contrárias</h5>
                                        {% if pasta.partesContrarias|length > 0 %}
                                            {% for parte in pasta.partesContrarias %}
                                                <div class="d-flex align-items-center gap-2 mb-3 pb-3 border-bottom">
                                                    <i class="bi bi-person-dash text-muted"></i>
                                                    <span>{{ parte.nome }}</span>
                                                </div>
                                            {% endfor %}
                                        {% else %}
                                            <p class="text-muted small mb-0"><i class="bi bi-info-circle me-1"></i> Nenhuma parte contrária registrada.</p>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>

                            {# Tab: Tarefas #}
                            <div class="tab-pane fade" id="tarefas" role="tabpanel" aria-labelledby="tarefas-tab">
                                {% if pasta.tarefas|length > 0 %}
                                    <div class="table-responsive">
                                        <table class="table table-hover align-middle">
                                            <thead>
                                                <tr>
                                                    <th>Título</th>
                                                    <th>Status</th>
                                                    <th>Prazo</th>
                                                    <th>Criada em</th>
                                                    <th></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                {% for tarefa in pasta.tarefas %}
                                                    {% set prazoInfo = tarefa.prazoInfo %}
                                                    <tr>
                                                        <td>{{ tarefa.titulo }}</td>
                                                        <td>
                                                            {% if tarefa.status == 'pendente' %}
                                                                <span class="badge text-bg-warning">Pendente</span>
                                                            {% elseif tarefa.status == 'em_revisao' %}
                                                                <span class="badge text-bg-info">Em revisão</span>
                                                            {% elseif tarefa.status == 'concluida' %}
                                                                <span class="badge text-bg-success">Concluída</span>
                                                            {% elseif tarefa.status == 'reaberta' %}
                                                                <span class="badge text-bg-danger">Reaberta</span>
                                                            {% else %}
                                                                <span class="badge text-bg-secondary">{{ tarefa.status }}</span>
                                                            {% endif %}
                                                        </td>
                                                        <td>
                                                            {% if prazoInfo.texto != '-' %}
                                                                <span class="badge text-bg-{{ prazoInfo.cor }}">{{ prazoInfo.texto }}</span>
                                                            {% else %}
                                                                <span class="text-muted">—</span>
                                                            {% endif %}
                                                        </td>
                                                        <td>{{ tarefa.dataCriacao|date('d/m/Y') }}</td>
                                                        <td>
                                                            <a href="{{ path('tarefa_show', {id: tarefa.id}) }}"
                                                               class="btn-action btn-action-view"
                                                               title="Visualizar tarefa"
                                                               aria-label="Visualizar tarefa">
                                                                <i class="bi bi-eye"></i>
                                                            </a>
                                                        </td>
                                                    </tr>
                                                {% endfor %}
                                            </tbody>
                                        </table>
                                    </div>
                                {% else %}
                                    <p class="text-muted"><i class="bi bi-info-circle me-1"></i> Nenhuma tarefa vinculada a esta pasta.</p>
                                {% endif %}
                            </div>

                            {# Tab: Detalhes #}
                            <div class="tab-pane fade" id="detalhes" role="tabpanel" aria-labelledby="detalhes-tab">
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="text-muted">
                                            <p class="text-sm mb-2"><i class="bi bi-calendar-plus me-2"></i> Criado em
                                                <b class="d-block">{{ pasta.createdAt|date('d/m/Y H:i') }}</b>
                                            </p>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="text-muted">
                                            <p class="text-sm mb-2"><i class="bi bi-calendar-check me-2"></i> Modificado em
                                                <b class="d-block">{% if pasta.modificadoEm %}{{ pasta.modificadoEm|date('d/m/Y H:i') }}{% else %}-{% endif %}</b>
                                            </p>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="text-muted">
                                            <p class="text-sm mb-2"><i class="bi bi-person-check me-2"></i> Criado por
                                                <b class="d-block">{% if pasta.criadoPor %}{{ pasta.criadoPor.fullName }}{% else %}-{% endif %}</b>
                                            </p>
                                            <p class="text-sm mb-2"><i class="bi bi-person-badge me-2"></i> Responsável
                                                <b class="d-block">{{ pasta.responsavel ? pasta.responsavel.fullName : '—' }}</b>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                    {# Right Column - Sidebar #}
                    <div class="col-12 col-md-12 col-lg-4 order-1 order-md-2">
                        {# Card: Documentação #}
                        <div class="card card-primary card-outline mb-3">
                            <div class="card-header">
                                <h3 class="card-title"><i class="bi bi-check2-square me-1"></i> Documentação</h3>
                            </div>
                            <div class="card-body">
                                {# Status #}
                                {% set totalCategorias = documentTypeOptions|length %}
                                {% set categoriasComDoc = 0 %}
                                {% for tipo, label in documentTypeOptions %}
                                    {% if (documentosPorTipo[tipo] ?? [])|length > 0 %}
                                        {% set categoriasComDoc = categoriasComDoc + 1 %}
                                    {% endif %}
                                {% endfor %}

                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h6 class="text-muted mb-0"><i class="bi bi-check2-square me-1"></i> Checklist de Documentação</h6>
                                    <span class="badge {{ categoriasComDoc == totalCategorias ? 'text-bg-success' : 'text-bg-warning' }}">
                                        {{ categoriasComDoc == totalCategorias ? 'Completo' : 'Pendente de Documentação' }}
                                    </span>
                                </div>

                                <ul class="list-unstyled mb-0">
                                    {% for tipo, label in documentTypeOptions %}
                                        {% set temDoc = (documentosPorTipo[tipo] ?? [])|length > 0 %}
                                        <li class="mb-2">
                                            <i class="bi {{ temDoc ? 'bi-check-circle-fill text-success' : 'bi-x-circle-fill text-danger' }} me-2"></i>
                                            {{ label }}
                                        </li>
                                    {% endfor %}
                                </ul>

                                <hr>

                                {# Arquivos por categoria #}
                                <h6 class="text-muted mb-3"><i class="bi bi-folder me-1"></i> Arquivos da Pasta</h6>
                                <ul class="list-unstyled mb-0">
                                    {% set hasDocuments = false %}
                                    {% for tipo, label in documentTypeOptions %}
                                        {% set docs = documentosPorTipo[tipo] ?? [] %}
                                        {% for doc in docs %}
                                            {% set hasDocuments = true %}
                                            <li class="mb-2">
                                                <a href="{{ path('pasta_documento_download', {id: doc.id}) }}" class="btn-link text-secondary text-decoration-none">
                                                    <i class="bi bi-download me-1"></i>
                                                    <i class="bi bi-file-earmark me-1"></i>
                                                    {{ doc.nomeOriginal }}
                                                </a>
                                                <small class="text-muted d-block ms-4">{{ label }} - {{ doc.uploadedAt|date('d/m/Y') }} · {{ (doc.tamanhoBytes / 1024 / 1024) < 1 ? (doc.tamanhoBytes / 1024)|round(1) ~ ' KB' : (doc.tamanhoBytes / 1024 / 1024)|round(2) ~ ' MB' }}</small>
                                            </li>
                                        {% endfor %}
                                    {% endfor %}
                                    {% if not hasDocuments %}
                                        <li class="text-muted"><i class="bi bi-info-circle me-1"></i> Nenhum arquivo enviado.</li>
                                    {% endif %}
                                </ul>
                            </div>
                            <div class="card-footer text-center">
                                <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#uploadDocumentosModal">
                                    <i class="bi bi-cloud-upload me-1"></i> Upload
                                </button>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
            <div class="card-footer">
                <div class="d-flex justify-content-between">
                    <a href="{{ path('pasta_index') }}" class="btn btn-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Voltar às Pastas
                    </a>
                    <div class="d-flex gap-2">
                        <a href="{{ path('pasta_edit', {id: pasta.id}) }}"
                           class="btn btn-outline-primary btn-sm"
                           title="Editar pasta"
                           aria-label="Editar pasta">
                            <i class="bi bi-pencil me-1"></i> Editar
                        </a>
                        <form method="post" action="{{ path('pasta_delete', {id: pasta.id}) }}"
                              onsubmit="return confirm('Tem certeza que deseja excluir esta pasta? Esta ação não pode ser desfeita.');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_pasta_' ~ pasta.id) }}">
                            <button type="submit"
                                    class="btn btn-outline-danger btn-sm"
                                    title="Excluir pasta"
                                    aria-label="Excluir pasta">
                                <i class="bi bi-trash me-1"></i> Excluir Pasta
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{# Modal: Preview de Documento (único reutilizável) #}
<div class="modal fade" id="previewDocModal" tabindex="-1" aria-labelledby="previewDocModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="previewDocModalLabel">
                    <i class="bi bi-eye me-1"></i> <span id="previewDocNome"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body p-0 d-flex align-items-center justify-content-center" style="min-height: 70vh;">
                <div id="previewDocConteudo" class="w-100 h-100"></div>
            </div>
            <div class="modal-footer">
                <a id="previewDocDownload" href="#" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-download me-1"></i> Baixar
                </a>
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Fechar</button>
            </div>
        </div>
    </div>
</div>

{# Modais: Editar Documento #}
{% for tipo, docs in documentosPorTipo %}
    {% for doc in docs %}
        {% set label = documentTypeOptions[tipo] ?? tipo %}
        <div class="modal fade" id="editDocModal{{ doc.id }}" tabindex="-1" aria-labelledby="editDocModalLabel{{ doc.id }}" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form method="post" action="{{ path('pasta_documento_edit', {id: doc.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('edit_documento_' ~ doc.id) }}">
                        <div class="modal-header">
                            <h5 class="modal-title" id="editDocModalLabel{{ doc.id }}">
                                <i class="bi bi-pencil me-1"></i> Editar documento
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                        </div>
                        <div class="modal-body">
                            <p class="text-muted small mb-3"><i class="bi bi-file-earmark me-1"></i>{{ doc.nomeOriginal }}</p>
                            <div class="mb-3">
                                <label class="form-label">Tipo de documento</label>
                                <select name="categoria" class="form-select" required>
                                    {% for valor, texto in documentTypeOptions %}
                                        <option value="{{ valor }}" {{ doc.categoria == valor ? 'selected' : '' }}>{{ texto }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Descrição</label>
                                <input type="text" name="descricao" class="form-control"
                                       value="{{ doc.descricao ?? '' }}" maxlength="500" placeholder="Descrição (opcional)">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Número (opcional)</label>
                                <input type="text" name="numero" class="form-control"
                                       value="{{ doc.numero ?? '' }}" maxlength="255" placeholder="Número">
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg me-1"></i> Salvar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    {% endfor %}
{% endfor %}

{# Modal: Upload de Documentos (Anexos) #}
<div class="modal fade" id="uploadDocumentosModal" tabindex="-1" aria-labelledby="uploadDocumentosModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="uploadDocumentosModalLabel">
                    <i class="bi bi-paperclip me-1"></i> Anexos
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>

            <div class="modal-body">

                {# ── Documentos já enviados ── #}
                {% set hasDocuments = false %}
                {% for tipo, docs in documentosPorTipo %}
                    {% if docs|length > 0 %}{% set hasDocuments = true %}{% endif %}
                {% endfor %}

                {% if hasDocuments %}
                <div class="mb-4">
                    <h6 class="text-muted mb-2"><i class="bi bi-archive me-1"></i> Documentos enviados</h6>
                    {% for tipo, docs in documentosPorTipo %}
                        {% if docs|length > 0 %}
                            {% set label = documentTypeOptions[tipo] ?? tipo %}
                            {% for doc in docs %}
                                <div class="d-flex align-items-center border rounded px-3 py-2 mb-2 gap-3">
                                    <i class="bi bi-file-earmark-text fs-5 text-primary flex-shrink-0"></i>
                                    <div class="flex-grow-1 overflow-hidden">
                                        <a href="{{ path('pasta_documento_download', {id: doc.id}) }}" target="_blank" rel="noopener noreferrer" class="text-truncate d-block fw-semibold">
                                            {{ doc.nomeOriginal }}
                                        </a>
                                        <small class="text-muted">
                                            {{ label }}
                                            {% if doc.descricao %} · {{ doc.descricao }}{% endif %}
                                            {% if doc.numero %} · Nº {{ doc.numero }}{% endif %}
                                            · {{ doc.uploadedAt|date('d/m/Y') }}
                                            · {{ (doc.tamanhoBytes / 1024 / 1024) < 1 ? (doc.tamanhoBytes / 1024)|round(1) ~ ' KB' : (doc.tamanhoBytes / 1024 / 1024)|round(2) ~ ' MB' }}
                                        </small>
                                    </div>
                                    <div class="d-flex gap-1 flex-shrink-0">
                                        <button type="button" class="btn btn-sm btn-outline-primary"
                                                title="Visualizar"
                                                data-bs-toggle="modal"
                                                data-bs-target="#previewDocModal"
                                                data-url="{{ path('pasta_documento_view', {id: doc.id}) }}"
                                                data-nome="{{ doc.nomeOriginal }}"
                                                data-mime="{{ doc.mimeType }}">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary"
                                                title="Editar"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editDocModal{{ doc.id }}">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <form method="post" action="{{ path('pasta_documento_delete', {id: doc.id}) }}" onsubmit="return confirm('Deseja excluir este documento?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_documento_' ~ doc.id) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Excluir">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            {% endfor %}
                        {% endif %}
                    {% endfor %}
                </div>
                <hr>
                {% endif %}

                {# ── Formulário de novos anexos ── #}
                <form id="formAnexos" method="post" enctype="multipart/form-data"
                      action="{{ path('pasta_documento_upload', {id: pasta.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('upload_documento_pasta_' ~ pasta.id) }}">

                    {# Toolbar superior #}
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <button type="button" id="btnAdicionarAnexo" class="btn btn-primary">
                            <i class="bi bi-plus-lg me-1"></i> Adicionar
                        </button>
                        <button type="button" id="btnLimparAnexos" class="btn btn-outline-secondary d-none">
                            <i class="bi bi-x-circle me-1"></i> Limpar
                        </button>
                        {# Input oculto — aceita múltiplos arquivos #}
                        <input type="file" id="inputAnexoOculto" multiple
                               accept=".pdf,.jpg,.jpeg,.png,.mp4,.mpeg,.mp3,.ogg,.opus,.wav,.wma,.mov,.kml,audio/*,video/*"
                               class="d-none">
                    </div>

                    {# Lista de arquivos selecionados #}
                    <div id="listaAnexos">
                        {# Itens injetados pelo JS #}
                    </div>

                    {# Botão enviar — aparece só quando há itens #}
                    <div id="areaEnviar" class="d-none mt-3 text-end">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-cloud-upload me-1"></i> Enviar todos
                        </button>
                    </div>
                </form>

            </div>{# /modal-body #}
        </div>
    </div>
</div>

<style>
.section-divider {
    border-color: rgba(0,0,0,0.07);
    margin: 0 0 1.25rem 0;
}
.copy-btn {
    cursor: pointer;
    opacity: 0.6;
    font-size: 0.85em;
    transition: opacity 0.2s, color 0.2s;
}
.copy-btn:hover {
    opacity: 1;
}
.copy-btn.copied {
    color: #198754 !important;
}
.vinculo-link {
    transition: background-color 0.2s;
    border-radius: 4px;
    padding: 8px;
    margin-left: -8px;
    margin-right: -8px;
}
.vinculo-link:hover {
    background-color: rgba(0,0,0,0.03);
}

/* Anexos */
.anexo-item {
    background: #fafafa;
    border: 1px solid #dee2e6;
    border-radius: 6px;
    padding: 12px 14px;
    margin-bottom: 10px;
}
.anexo-item .anexo-nome {
    font-weight: 600;
    font-size: .92rem;
    word-break: break-all;
}
.anexo-item .anexo-tamanho {
    font-size: .8rem;
    color: #6c757d;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {

    /* ── Preview de documento ── */
    const previewModal     = document.getElementById('previewDocModal');
    const previewConteudo  = document.getElementById('previewDocConteudo');
    const previewNome      = document.getElementById('previewDocNome');
    const previewDownload  = document.getElementById('previewDocDownload');

    previewModal.addEventListener('show.bs.modal', function (e) {
        const btn  = e.relatedTarget;
        const url  = btn.dataset.url;
        const nome = btn.dataset.nome;
        const mime = btn.dataset.mime;

        previewNome.textContent = nome;
        previewDownload.href = url.replace('/visualizar', '/download');
        previewConteudo.innerHTML = '';

        if (mime === 'application/pdf') {
            previewConteudo.innerHTML =
                `<iframe src="${url}" class="w-100 border-0" style="height:75vh;" title="${nome}"></iframe>`;
        } else if (mime.startsWith('image/')) {
            previewConteudo.innerHTML =
                `<img src="${url}" class="img-fluid d-block mx-auto p-3" style="max-height:75vh;object-fit:contain;" alt="${nome}">`;
        } else if (mime.startsWith('audio/')) {
            previewConteudo.innerHTML =
                `<div class="p-4 text-center w-100">
                    <i class="bi bi-file-earmark-music display-1 text-muted d-block mb-3"></i>
                    <p class="text-muted mb-3">${nome}</p>
                    <audio controls class="w-100" style="max-width:500px;">
                        <source src="${url}" type="${mime}">
                        Seu navegador não suporta reprodução de áudio.
                    </audio>
                 </div>`;
        } else if (mime.startsWith('video/')) {
            previewConteudo.innerHTML =
                `<video controls class="w-100 d-block" style="max-height:75vh;">
                    <source src="${url}" type="${mime}">
                    Seu navegador não suporta reprodução de vídeo.
                 </video>`;
        } else {
            previewConteudo.innerHTML =
                `<div class="p-5 text-center text-muted w-100">
                    <i class="bi bi-file-earmark display-1 d-block mb-3"></i>
                    <p>Pré-visualização não disponível para este tipo de arquivo.</p>
                    <a href="${url.replace('/visualizar', '/download')}" class="btn btn-primary">
                        <i class="bi bi-download me-1"></i> Baixar arquivo
                    </a>
                 </div>`;
        }
    });

    previewModal.addEventListener('hide.bs.modal', function () {
        previewConteudo.innerHTML = '';
    });

    /* ── Tooltips ── */
    var tooltipEls = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    tooltipEls.forEach(function (el) { new bootstrap.Tooltip(el); });

    /* ── Copy buttons ── */
    document.querySelectorAll('.copy-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            const text = this.getAttribute('data-copy');
            navigator.clipboard.writeText(text).then(() => {
                this.classList.replace('bi-copy', 'bi-check-lg');
                this.classList.add('copied');
                setTimeout(() => {
                    this.classList.replace('bi-check-lg', 'bi-copy');
                    this.classList.remove('copied');
                }, 1500);
            });
        });
    });

    /* ── Anexos ── */
    const documentTypeOptions = {{ documentTypeOptions|json_encode|raw }};

    const btnAdicionar   = document.getElementById('btnAdicionarAnexo');
    const inputOculto    = document.getElementById('inputAnexoOculto');
    const listaAnexos    = document.getElementById('listaAnexos');
    const areaEnviar     = document.getElementById('areaEnviar');

    // Contador global para índices únicos
    let indiceGlobal = 0;

    function formatarTamanho(bytes) {
        if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / 1024 / 1024).toFixed(2) + ' MB';
    }

    function buildSelectOpcoes() {
        let html = '<option value="">Selecione o tipo</option>';
        for (const [valor, texto] of Object.entries(documentTypeOptions)) {
            html += `<option value="${valor}">${texto}</option>`;
        }
        return html;
    }

    function adicionarItem(file) {
        const idx = indiceGlobal++;
        const div = document.createElement('div');
        div.className = 'anexo-item';
        div.dataset.idx = idx;
        div._file = file; // arquivo associado diretamente ao elemento

        div.innerHTML = `
            <div class="d-flex align-items-start gap-3">
                <i class="bi bi-file-earmark-text fs-4 text-primary flex-shrink-0 mt-1"></i>

                <div class="flex-grow-1">
                    <div class="anexo-nome">${file.name}</div>
                    <div class="anexo-tamanho mb-2">${formatarTamanho(file.size)}</div>

                    <div class="row g-2">
                        <div class="col-12 col-md-4">
                            <label class="form-label form-label-sm mb-1">Tipo de documento</label>
                            <select name="categorias[${idx}]" class="form-select form-select-sm" required>
                                ${buildSelectOpcoes()}
                            </select>
                        </div>
                        <div class="col-12 col-md-5">
                            <label class="form-label form-label-sm mb-1">Descrição</label>
                            <input type="text" name="descricoes[${idx}]" class="form-control form-control-sm"
                                   placeholder="Descrição (opcional)" maxlength="500">
                        </div>
                        <div class="col-12 col-md-3">
                            <label class="form-label form-label-sm mb-1">Número (opcional)</label>
                            <input type="text" name="numeros[${idx}]" class="form-control form-control-sm"
                                   placeholder="Número" maxlength="255">
                        </div>
                    </div>
                </div>

                <button type="button" class="btn btn-sm btn-outline-danger flex-shrink-0 mt-1 btn-remover-anexo"
                        title="Remover">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
        `;

        div.querySelector('.btn-remover-anexo').addEventListener('click', function () {
            div.remove();
            atualizarVisibilidade();
        });

        listaAnexos.appendChild(div);
    }

    const btnLimpar = document.getElementById('btnLimparAnexos');

    function atualizarVisibilidade() {
        const temItens = listaAnexos.children.length > 0;
        areaEnviar.classList.toggle('d-none', !temItens);
        btnLimpar.classList.toggle('d-none', !temItens);
    }

    btnLimpar.addEventListener('click', function () {
        listaAnexos.innerHTML = '';
        inputOculto.value = '';
        atualizarVisibilidade();
    });

    btnAdicionar.addEventListener('click', function () {
        inputOculto.value = '';
        inputOculto.click();
    });

    inputOculto.addEventListener('change', function () {
        Array.from(this.files).forEach(function (file) {
            adicionarItem(file);
        });
        atualizarVisibilidade();
    });

    // No submit: reindexar campos e reconstruir FileList a partir dos elementos
    document.getElementById('formAnexos').addEventListener('submit', function (e) {
        const itens = Array.from(listaAnexos.querySelectorAll('.anexo-item'));

        if (itens.length === 0) {
            e.preventDefault();
            return;
        }

        // Reindexar campos de metadados para 0,1,2... na ordem atual da lista
        itens.forEach(function (item, novoIdx) {
            const oldIdx = parseInt(item.dataset.idx, 10);
            ['categorias', 'descricoes', 'numeros'].forEach(function (campo) {
                const el = item.querySelector(`[name^="${campo}["]`);
                if (el) el.name = `${campo}[${novoIdx}]`;
            });
        });

        // Reconstruir FileList com os arquivos na mesma ordem
        const dt = new DataTransfer();
        itens.forEach(function (item) {
            if (item._file) dt.items.add(item._file);
        });

        inputOculto.name = 'arquivos[]';
        inputOculto.files = dt.files;
    });
});
</script>
{% endblock %}
