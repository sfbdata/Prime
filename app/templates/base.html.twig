<!DOCTYPE html>
<html lang="pt-BR">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
        <meta name="color-scheme" content="light dark">
        <title>{% block title %}JusPrime{% endblock %}</title>

        {# Fonts #}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/source-sans-3@5.0.12/index.css" crossorigin="anonymous">

        {# OverlayScrollbars #}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.11.0/styles/overlayscrollbars.min.css" crossorigin="anonymous">

        {# Bootstrap Icons #}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" crossorigin="anonymous">

        {# Font Awesome (for backward compatibility) #}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.5.2/css/all.min.css" crossorigin="anonymous">

        {# AdminLTE 4 #}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-rc3/dist/css/adminlte.min.css" crossorigin="anonymous">

        {# Select2 #}
        <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" crossorigin="anonymous">

        {# App Custom Styles #}
        <link rel="stylesheet" href="/css/app.css">
        {% block stylesheets %}{% endblock %}
    </head>
    {#
        IMPORTANTE: NÃO colocar sidebar-collapse nem sidebar-open aqui.
        O AdminLTE detecta essas classes e interfere no nosso controle customizado.
        O sidebar é gerenciado exclusivamente pelo JS do _sidebar.html.twig.
    #}
    <body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
        {% if app.user %}
            {# App Wrapper #}
            <div class="app-wrapper">

                {# ============================================================
                   HEADER FIXO — estilo PJe
                   ============================================================ #}
                <nav class="app-header navtop" id="mainHeader" tabindex="-1">

                    {# ── Barra principal azul ── #}
                    <div class="navtop-inner">

                        {# Lado esquerdo: toggle + brand + título da página #}
                        <div class="navtop-left">
                            {#
                                IMPORTANTE: data-lte-toggle="sidebar" REMOVIDO.
                                O AdminLTE interceptaria o clique e abriria o sidebar
                                do jeito dele. O controle é feito pelo nosso JS.
                            #}
                            <button class="sidebar-toggle-btn" id="sidebarToggleBtn"
                                    type="button"
                                    aria-label="Abrir/fechar menu">
                                <i class="bi bi-list"></i>
                            </button>
                            <a href="{{ path('homepage') }}" class="navtop-brand">
                                <span class="navtop-brand-text">JusPrime</span>
                            </a>
                            {# Separador + título da página atual #}
                            {% set pageTitle = '' %}
                            {% set currentRoute = app.request.attributes.get('_route')|default('') %}
                            {% if currentRoute starts with 'cliente_' %}
                                {% set pageTitle = 'Clientes' %}
                            {% elseif currentRoute starts with 'processo_' %}
                                {% set pageTitle = 'Processos' %}
                            {% elseif currentRoute starts with 'tarefa_' %}
                                {% set pageTitle = 'Tarefas' %}
                            {% elseif currentRoute starts with 'agenda_' %}
                                {% set pageTitle = 'Agenda' %}
                            {% elseif currentRoute starts with 'servicedesk_' %}
                                {% set pageTitle = 'Service Desk' %}
                            {% elseif currentRoute starts with 'pre_cadastro_' %}
                                {% set pageTitle = 'Pré-Cadastros' %}
                            {% elseif currentRoute starts with 'app_tenant_' %}
                                {% set pageTitle = 'Tenants' %}
                            {% elseif currentRoute starts with 'audit_log_' %}
                                {% set pageTitle = 'Auditoria' %}
                            {% elseif currentRoute == 'invite_user' %}
                                {% set pageTitle = 'Convidar Usuários' %}
                            {% elseif currentRoute == 'app_profile' %}
                                {% set pageTitle = 'Meu Perfil' %}
                            {% elseif currentRoute in ['homepage', 'home'] %}
                                {% set pageTitle = '' %}
                            {% endif %}
                            {% if pageTitle %}
                                <span class="navtop-page-sep">|</span>
                                <span class="navtop-page-title">{{ pageTitle }}</span>
                            {% endif %}
                        </div>

                        {# Lado direito: notificações + fullscreen + usuário #}
                        <div class="navtop-right">

                            {# Notificações #}
                            <div class="navtop-action dropdown">
                                <a href="#" class="navtop-action-btn"
                                   data-bs-toggle="dropdown" id="notificacaoDropdownToggle"
                                   aria-label="Notificações">
                                    <i class="bi bi-bell-fill"></i>
                                    <span class="navtop-badge" id="notificacaoBadge"
                                          style="{% if notificacoesCount == 0 %}display:none;{% endif %}">
                                        {{ notificacoesCount > 9 ? '9+' : notificacoesCount }}
                                    </span>
                                </a>
                                <div class="dropdown-menu dropdown-menu-end shadow notif-dropdown"
                                     id="notificacaoDropdownMenu">
                                    <div class="notif-header">
                                        <i class="bi bi-bell me-1"></i>
                                        <span id="notificacaoCountText">{{ notificacoesCount }}</span> notificação(ões)
                                    </div>
                                    <div class="dropdown-divider m-0"></div>
                                    <div id="notificacaoListContainer">
                                        {% if notificacoes|length > 0 %}
                                            {% for notif in notificacoes %}
                                                <a href="{{ notif.url ?? (notif.tarefa ? path('tarefa_show', {id: notif.tarefa.id}) : '#') }}"
                                                   class="dropdown-item notif-item{% if not notif.lida %} notif-unread{% endif %}">
                                                    <i class="bi {{ notif.icone }} notif-icon"></i>
                                                    <div class="notif-body">
                                                        <div class="notif-title">{{ notif.titulo }}</div>
                                                        <div class="notif-msg">{{ notif.mensagem }}</div>
                                                        <div class="notif-time">{{ notif.tempoRelativo }}</div>
                                                    </div>
                                                </a>
                                                <div class="dropdown-divider m-0"></div>
                                            {% endfor %}
                                        {% else %}
                                            <a href="#" class="dropdown-item text-center text-muted py-3" id="notificacaoEmpty">
                                                <i class="bi bi-check-circle me-2"></i> Nenhuma notificação
                                            </a>
                                        {% endif %}
                                    </div>
                                    <a href="{{ path('notificacao_index') }}" class="dropdown-item text-center notif-footer">
                                        <i class="bi bi-list-ul me-1"></i> Ver todas as notificações
                                    </a>
                                </div>
                            </div>

                            {# Fullscreen #}
                            <a href="#" class="navtop-action-btn" data-lte-toggle="fullscreen"
                               aria-label="Tela cheia">
                                <i data-lte-icon="maximize" class="bi bi-arrows-fullscreen"></i>
                                <i data-lte-icon="minimize" class="bi bi-fullscreen-exit" style="display:none"></i>
                            </a>

                            {# Usuário #}
                            <div class="navtop-action dropdown menu-usuario">
                                <a href="#" class="navtop-avatar-btn dropdown-toggle"
                                   data-bs-toggle="dropdown" aria-expanded="false"
                                   aria-label="Menu do usuário">
                                    <div class="navtop-user-info d-none d-md-flex">
                                        <span class="navtop-username">{{ app.user.fullName }}</span>
                                        <span class="navtop-last-access">
                                            Último Acesso Em:
                                            {{ app.user.lastLogin is defined and app.user.lastLogin
                                                ? app.user.lastLogin|date('d/m/Y - H:i:s')
                                                : 'não disponível' }}
                                        </span>
                                    </div>
                                    <span class="navtop-avatar">
                                        {{ app.user.fullName|slice(0,1)|upper }}
                                    </span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow usuario-dropdown">
                                    <li class="usuario-dropdown-header">
                                        <span class="usuario-avatar-lg">
                                            {{ app.user.fullName|slice(0,1)|upper }}
                                        </span>
                                        <div class="usuario-info">
                                            <div class="usuario-name">{{ app.user.fullName }}</div>
                                            <div class="usuario-email">{{ app.user.email }}</div>
                                        </div>
                                    </li>
                                    <li><hr class="dropdown-divider my-0"></li>
                                    <li>
                                        <a href="{{ path('app_profile') }}" class="dropdown-item d-flex align-items-center gap-2">
                                            <i class="bi bi-person"></i> Meu Perfil
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider my-0"></li>
                                    <li>
                                        <a href="{{ path('app_logout') }}" class="dropdown-item d-flex align-items-center gap-2 text-danger">
                                            <i class="bi bi-box-arrow-right"></i> Sair
                                        </a>
                                    </li>
                                </ul>
                            </div>

                        </div>{# /navtop-right #}
                    </div>{# /navtop-inner #}

                    {# ── Subnav branco ── #}
                    <div class="navtop-subnav">
                        <a href="{{ path('homepage') }}"
                           class="navtop-subnav-link {{ app.request.attributes.get('_route') in ['homepage','home'] ? 'active' : '' }}">
                            Home
                        </a>
                        <a href="{{ path('cliente_index') }}"
                           class="navtop-subnav-link {{ app.request.attributes.get('_route') starts with 'cliente_' ? 'active' : '' }}">
                            Clientes
                        </a>
                        <a href="{{ path('processo_index') }}"
                           class="navtop-subnav-link {{ app.request.attributes.get('_route') starts with 'processo_' ? 'active' : '' }}">
                            Processos
                        </a>
                        <a href="{{ path('pasta_index') }}"
                           class="navtop-subnav-link {{ app.request.attributes.get('_route') starts with 'pasta_' ? 'active' : '' }}">
                            Pastas
                        </a>
                    </div>

                </nav>
                {# ============================================================
                   FIM HEADER
                   ============================================================ #}

                {# Sidebar #}
                {% include '_sidebar.html.twig' %}

                {# Main Content #}
                <main class="app-main" id="main" tabindex="-1">
                    <div class="app-content-header">
                        <div class="container-fluid">
                            {% for label, messages in app.flashes %}
                                {% for message in messages %}
                                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                                        {{ message }}
                                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
                                    </div>
                                {% endfor %}
                            {% endfor %}
                        </div>
                    </div>
                    <div class="app-content">
                        <div class="container-fluid">
                            {% block body %}{% endblock %}
                        </div>
                    </div>
                </main>

            </div>{# /app-wrapper #}

        {% else %}
            <div class="no-sidebar">
                {{ block('body') }}
            </div>
        {% endif %}

        {# Scripts #}
        <script src="https://code.jquery.com/jquery-3.6.0.min.js" crossorigin="anonymous"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
        <script src="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.11.0/browser/overlayscrollbars.browser.es6.min.js" crossorigin="anonymous"></script>
        <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js" crossorigin="anonymous"></script>
        <script src="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-rc3/dist/js/adminlte.min.js" crossorigin="anonymous"></script>

        <script>
            document.addEventListener('DOMContentLoaded', function () {

                // ── Polling de notificações a cada 30 s
                function atualizarNotificacoes() {
                    fetch('/notificacoes/count')
                        .then(r => r.json())
                        .then(data => {
                            const badge    = document.getElementById('notificacaoBadge');
                            const countTxt = document.getElementById('notificacaoCountText');
                            if (!badge || !countTxt) return;
                            const n = data.count;
                            countTxt.textContent = n;
                            badge.textContent    = n > 9 ? '9+' : n;
                            badge.style.display  = n > 0 ? '' : 'none';
                        })
                        .catch(e => console.log('Notificações:', e));
                }
                setInterval(atualizarNotificacoes, 30000);

                // ── Atualiza dropdown ao abrir
                const dropToggle = document.getElementById('notificacaoDropdownToggle');
                if (dropToggle) {
                    dropToggle.addEventListener('show.bs.dropdown', function () {
                        fetch('/notificacoes/lista-dropdown')
                            .then(r => r.json())
                            .then(data => {
                                const container = document.getElementById('notificacaoListContainer');
                                const countTxt  = document.getElementById('notificacaoCountText');
                                const badge     = document.getElementById('notificacaoBadge');
                                if (container && data.html) container.innerHTML = data.html;
                                if (countTxt) countTxt.textContent = data.count;
                                if (badge) {
                                    badge.textContent   = data.count > 9 ? '9+' : data.count;
                                    badge.style.display = data.count > 0 ? '' : 'none';
                                }
                            })
                            .catch(e => console.log('Dropdown notif:', e));
                    });
                }
            });
        </script>
        {% block javascripts %}{% endblock %}
        {#
            SCRIPT CONFLITANTE REMOVIDO.
            O bloco abaixo foi removido pois manipulava sidebar-collapse no body
            e conflitava com o controle do sidebar em _sidebar.html.twig:

            document.addEventListener('click', function(e) {
                var sidebar = document.getElementById('pjeSidebar');
                var btn = document.getElementById('sidebarToggleBtn');
                if (!document.body.classList.contains('sidebar-collapse') && ...) {
                    document.body.classList.add('sidebar-collapse');
                }
            });
        #}
    </body>
</html>
