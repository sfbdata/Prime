<!DOCTYPE html>
<html lang="pt-BR">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
        <meta name="color-scheme" content="light dark">
        <title>{% block title %}JusPrime{% endblock %}</title>

        {# Fonts #}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/source-sans-3@5.0.12/index.css" crossorigin="anonymous">
        
        {# OverlayScrollbars #}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.11.0/styles/overlayscrollbars.min.css" crossorigin="anonymous">
        
        {# Bootstrap Icons #}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" crossorigin="anonymous">
        
        {# Font Awesome (for backward compatibility) #}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.5.2/css/all.min.css" crossorigin="anonymous">
        
        {# AdminLTE 4 #}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-rc3/dist/css/adminlte.min.css" crossorigin="anonymous">
        
        {# Select2 #}
        <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" crossorigin="anonymous">

        {# App Custom Styles #}
        <link rel="stylesheet" href="/css/app.css">
        {% block stylesheets %}{% endblock %}
    </head>
    <body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
        {% if app.user %}
            {# App Wrapper #}
            <div class="app-wrapper">
                {# Header / Navbar #}
                <nav class="app-header navbar navbar-expand bg-body">
                    <div class="container-fluid">
                        {# Start Navbar Links #}
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                                    <i class="bi bi-list"></i>
                                </a>
                            </li>
                            <li class="nav-item d-none d-md-block">
                                <a href="{{ path('homepage') }}" class="nav-link">Home</a>
                            </li>
                            <li class="nav-item d-none d-md-block">
                                <a href="{{ path('cliente_index') }}" class="nav-link">Clientes</a>
                            </li>
                            <li class="nav-item d-none d-md-block">
                                <a href="{{ path('tarefa_minhas') }}" class="nav-link">Tarefas</a>
                            </li>
                        </ul>
                        {# End Start Navbar Links #}

                        {# End Navbar Links #}
                        <ul class="navbar-nav ms-auto">
                            {# Notifications Dropdown #}
                            <li class="nav-item dropdown">
                                <a class="nav-link" data-bs-toggle="dropdown" href="#" id="notificacaoDropdownToggle">
                                    <i class="bi bi-bell-fill"></i>
                                    <span class="navbar-badge badge text-bg-danger" id="notificacaoBadge" style="{% if notificacoesCount == 0 %}display:none;{% endif %}">{{ notificacoesCount > 9 ? '9+' : notificacoesCount }}</span>
                                </a>
                                <div class="dropdown-menu dropdown-menu-lg dropdown-menu-end" style="max-width: 350px;" id="notificacaoDropdownMenu">
                                    <span class="dropdown-item dropdown-header" id="notificacaoHeader">
                                        <span id="notificacaoCountText">{{ notificacoesCount }}</span> Notificação(ões) não lida(s)
                                    </span>
                                    <div class="dropdown-divider"></div>
                                    <div id="notificacaoListContainer">
                                    {% if notificacoes|length > 0 %}
                                        {% for notif in notificacoes %}
                                            <a href="{{ notif.url ?? (notif.tarefa ? path('tarefa_show', {id: notif.tarefa.id}) : '#') }}" class="dropdown-item{% if not notif.lida %} bg-light{% endif %}">
                                                <div class="d-flex align-items-start">
                                                    <i class="bi {{ notif.icone }} me-2 mt-1"></i>
                                                    <div class="flex-grow-1">
                                                        <div class="fw-semibold small">{{ notif.titulo }}</div>
                                                        <div class="text-muted small text-truncate" style="max-width: 250px;">{{ notif.mensagem }}</div>
                                                        <div class="text-muted smaller">{{ notif.tempoRelativo }}</div>
                                                    </div>
                                                </div>
                                            </a>
                                            <div class="dropdown-divider"></div>
                                        {% endfor %}
                                    {% else %}
                                        <a href="#" class="dropdown-item text-center text-muted" id="notificacaoEmpty">
                                            <i class="bi bi-check-circle me-2"></i> Nenhuma notificação
                                        </a>
                                    {% endif %}
                                    </div>
                                    <a href="{{ path('notificacao_index') }}" class="dropdown-item dropdown-footer text-center">
                                        <i class="bi bi-list-ul me-1"></i> Ver todas as notificações
                                    </a>
                                </div>
                            </li>
                            
                            {# Fullscreen Toggle #}
                            <li class="nav-item">
                                <a class="nav-link" href="#" data-lte-toggle="fullscreen">
                                    <i data-lte-icon="maximize" class="bi bi-arrows-fullscreen"></i>
                                    <i data-lte-icon="minimize" class="bi bi-fullscreen-exit" style="display: none"></i>
                                </a>
                            </li>
                            
                            {# User Menu Dropdown #}
                            <li class="nav-item dropdown user-menu">
                                <a href="#" class="nav-link dropdown-toggle d-flex align-items-center" data-bs-toggle="dropdown">
                                    <span class="d-flex align-items-center justify-content-center rounded-circle bg-primary text-white flex-shrink-0" style="width:32px;height:32px;font-size:14px;">
                                        {{ app.user.fullName|slice(0,1)|upper }}
                                    </span>
                                    <span class="d-none d-md-inline ms-2 text-truncate" style="max-width:150px;">{{ app.user.fullName }}</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-end">
                                    <li class="user-header text-bg-primary">
                                        <span class="d-flex align-items-center justify-content-center rounded-circle bg-white text-primary mx-auto" style="width:80px;height:80px;font-size:32px;">
                                            {{ app.user.fullName|slice(0,1)|upper }}
                                        </span>
                                        <p>
                                            {{ app.user.fullName }}
                                            <small>{{ app.user.email }}</small>
                                        </p>
                                    </li>
                                    <li class="user-footer">
                                        <a href="{{ path('app_profile') }}" class="btn btn-default btn-flat">
                                            <i class="bi bi-person me-1"></i> Perfil
                                        </a>
                                        <a href="{{ path('app_logout') }}" class="btn btn-default btn-flat float-end">
                                            <i class="bi bi-box-arrow-right me-1"></i> Sair
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                        {# End End Navbar Links #}
                    </div>
                </nav>
                {# End Header #}

                {# Sidebar #}
                {% include '_sidebar.html.twig' %}

                {# Main Content #}
                <main class="app-main">
                    <div class="app-content-header">
                        <div class="container-fluid">
                            {% for label, messages in app.flashes %}
                                {% for message in messages %}
                                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                                        {{ message }}
                                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
                                    </div>
                                {% endfor %}
                            {% endfor %}
                        </div>
                    </div>
                    <div class="app-content">
                        <div class="container-fluid">
                            {% block body %}{% endblock %}
                        </div>
                    </div>
                </main>
                {# End Main Content #}
            </div>
            {# End App Wrapper #}
        {% else %}
            <div class="no-sidebar">
                {{ block('body') }}
            </div>
        {% endif %}

        {# Scripts #}
        <script src="https://code.jquery.com/jquery-3.6.0.min.js" crossorigin="anonymous"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
        <script src="https://cdn.jsdelivr.net/npm/overlayscrollbars@2.11.0/browser/overlayscrollbars.browser.es6.min.js" crossorigin="anonymous"></script>
        <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js" crossorigin="anonymous"></script>

        {# AdminLTE 4 #}
        <script src="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-rc3/dist/js/adminlte.min.js" crossorigin="anonymous"></script>
        
        <script>
            document.addEventListener('DOMContentLoaded', function() {

                // Polling de notificações a cada 30 segundos
                function atualizarNotificacoes() {
                    fetch('/notificacoes/count')
                        .then(response => response.json())
                        .then(data => {
                            const badge = document.getElementById('notificacaoBadge');
                            const countText = document.getElementById('notificacaoCountText');
                            
                            if (badge && countText) {
                                const count = data.count;
                                countText.textContent = count;
                                
                                if (count > 0) {
                                    badge.textContent = count > 9 ? '9+' : count;
                                    badge.style.display = '';
                                } else {
                                    badge.style.display = 'none';
                                }
                            }
                        })
                        .catch(err => console.log('Erro ao buscar notificações:', err));
                }

                setInterval(atualizarNotificacoes, 30000);

                const dropdownToggle = document.getElementById('notificacaoDropdownToggle');
                if (dropdownToggle) {
                    dropdownToggle.addEventListener('show.bs.dropdown', function() {
                        fetch('/notificacoes/lista-dropdown')
                            .then(response => response.json())
                            .then(data => {
                                const container = document.getElementById('notificacaoListContainer');
                                const countText = document.getElementById('notificacaoCountText');
                                const badge = document.getElementById('notificacaoBadge');
                                
                                if (container && data.html) {
                                    container.innerHTML = data.html;
                                }
                                if (countText) {
                                    countText.textContent = data.count;
                                }
                                if (badge) {
                                    if (data.count > 0) {
                                        badge.textContent = data.count > 9 ? '9+' : data.count;
                                        badge.style.display = '';
                                    } else {
                                        badge.style.display = 'none';
                                    }
                                }
                            })
                            .catch(err => console.log('Erro ao atualizar dropdown:', err));
                    });
                }
            });
        </script>
        {% block javascripts %}{% endblock %}
    </body>
</html>