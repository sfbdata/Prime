{% set normalizedStatus = status ?: 'SEM_CONTRATO' %}

{% set badgeClass =
    normalizedStatus == 'ATIVO' ? 'text-bg-success' :
    (normalizedStatus in ['INATIVO', 'ENCERRADO'] ? 'text-bg-danger' :
    (normalizedStatus == 'SEM_CONTRATO' ? 'text-bg-secondary' :
    (normalizedStatus == 'PENDENTE' ? 'text-bg-warning' :
    (normalizedStatus == 'EM_ANDAMENTO' ? 'text-bg-info' :
    (normalizedStatus == 'FINALIZADO' ? 'text-bg-success' :
    (normalizedStatus == 'CANCELADO' ? 'text-bg-danger' : 'text-bg-secondary')))))) %}

{% set label =
    normalizedStatus == 'ATIVO' ? 'Ativo' :
    (normalizedStatus in ['INATIVO', 'ENCERRADO'] ? 'Inativo' :
    (normalizedStatus == 'SEM_CONTRATO' ? 'Sem contrato' :
    (normalizedStatus == 'PENDENTE' ? 'Pendente' :
    (normalizedStatus == 'EM_ANDAMENTO' ? 'Em Andamento' :
    (normalizedStatus == 'FINALIZADO' ? 'Finalizado' :
    (normalizedStatus == 'CANCELADO' ? 'Cancelado' : normalizedStatus)))))) %}

<span class="badge {{ badgeClass }}">{{ label }}</span>
