{% extends 'base.html.twig' %}

{% block title %}Evento - {{ evento.titulo }}{% endblock %}

{% block body %}
<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <span class="badge" style="background-color: {{ evento.cor }};">&nbsp;</span>
                    {{ evento.titulo }}
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-end">
                    <li class="breadcrumb-item"><a href="{{ path('homepage') }}">Home</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('agenda_index') }}">Agenda</a></li>
                    <li class="breadcrumb-item active">Detalhes</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        {% if evento.status == 'cancelado' %}
        <div class="alert alert-danger d-flex align-items-center" role="alert">
            <i class="bi bi-x-circle me-2"></i>
            <div>Este evento foi <strong>cancelado</strong>.</div>
        </div>
        {% endif %}

        <div class="row">
            <div class="col-md-8">
                <div class="card card-primary card-outline">
                    <div class="card-header">
                        <h3 class="card-title"><i class="bi bi-calendar-event me-1"></i> Detalhes do Evento</h3>
                        <div class="card-tools">
                            <span class="badge {{ evento.statusBadgeClass }}">{{ evento.statusLabel }}</span>
                        </div>
                    </div>
                    <div class="card-body">
                        {# Info Boxes #}
                        <div class="row">
                            <div class="col-12 col-sm-4">
                                <div class="info-box bg-light">
                                    <div class="info-box-content">
                                        <span class="info-box-text text-center text-muted">Início</span>
                                        <span class="info-box-number text-center text-muted mb-0">
                                            {{ evento.dataInicio|date('d/m/Y') }}
                                            {% if not evento.diaInteiro %}
                                            <br><small>{{ evento.dataInicio|date('H:i') }}</small>
                                            {% endif %}
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-sm-4">
                                <div class="info-box bg-light">
                                    <div class="info-box-content">
                                        <span class="info-box-text text-center text-muted">Fim</span>
                                        <span class="info-box-number text-center text-muted mb-0">
                                            {{ evento.dataFim|date('d/m/Y') }}
                                            {% if not evento.diaInteiro %}
                                            <br><small>{{ evento.dataFim|date('H:i') }}</small>
                                            {% endif %}
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-sm-4">
                                <div class="info-box bg-light">
                                    <div class="info-box-content">
                                        <span class="info-box-text text-center text-muted">Participantes</span>
                                        <span class="info-box-number text-center text-muted mb-0">{{ evento.participantes|length }}</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr>

                        <div class="row">
                            <div class="col-md-12">
                                <h5><i class="bi bi-text-paragraph me-1"></i> Descrição</h5>
                                <p class="text-muted">{{ evento.descricao ?: 'Sem descrição.' }}</p>
                            </div>
                        </div>

                        {% if evento.local %}
                        <div class="row mt-3">
                            <div class="col-md-12">
                                <h5><i class="bi bi-geo-alt me-1"></i> Local</h5>
                                <p>{{ evento.local }}</p>
                            </div>
                        </div>
                        {% endif %}

                        {% if evento.participantes|length > 0 %}
                        <div class="row mt-3">
                            <div class="col-md-12">
                                <h5><i class="bi bi-people me-1"></i> Participantes</h5>
                                <ul class="list-unstyled">
                                    {% for participante in evento.participantes %}
                                    <li><i class="bi bi-person me-1"></i> {{ participante.fullName }} ({{ participante.email }})</li>
                                    {% endfor %}
                                </ul>
                            </div>
                        </div>
                        {% endif %}

                        {% if evento.recorrente %}
                        <div class="row mt-3">
                            <div class="col-md-12">
                                <h5><i class="bi bi-arrow-repeat me-1"></i> Recorrência</h5>
                                <p>
                                    Repetir: <strong>{{ evento.tipoRecorrencia|capitalize }}</strong>
                                    {% if evento.fimRecorrencia %}
                                    até {{ evento.fimRecorrencia|date('d/m/Y') }}
                                    {% endif %}
                                </p>
                            </div>
                        </div>
                        {% endif %}
                    </div>
                    <div class="card-footer">
                        <a href="{{ path('agenda_editar', {id: evento.id}) }}" class="btn btn-warning">
                            <i class="bi bi-pencil me-1"></i> Editar
                        </a>
                        <a href="{{ path('agenda_index') }}" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Voltar ao Calendário
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card card-outline card-secondary">
                    <div class="card-header">
                        <h3 class="card-title"><i class="bi bi-info-circle me-1"></i> Informações</h3>
                    </div>
                    <div class="card-body">
                        <p><strong>Criado por:</strong> {{ evento.criador.fullName }}</p>
                        <p><strong>Criado em:</strong> {{ evento.criadoEm|date('d/m/Y H:i') }}</p>
                        {% if evento.modificadoEm %}
                        <p><strong>Modificado em:</strong> {{ evento.modificadoEm|date('d/m/Y H:i') }}</p>
                        {% endif %}
                        <p><strong>Cor:</strong> <span class="badge" style="background-color: {{ evento.cor }};">&nbsp;&nbsp;&nbsp;</span></p>
                        {% if evento.diaInteiro %}
                        <p><i class="bi bi-check-circle text-success me-1"></i> Evento de dia inteiro</p>
                        {% endif %}
                    </div>
                </div>

                {% if evento.status != 'cancelado' %}
                <div class="card card-outline card-danger">
                    <div class="card-header">
                        <h3 class="card-title"><i class="bi bi-exclamation-triangle me-1"></i> Ações</h3>
                    </div>
                    <div class="card-body">
                        <form method="POST" action="{{ path('agenda_cancelar', {id: evento.id}) }}" class="mb-2">
                            <input type="hidden" name="_token" value="{{ csrf_token('cancelar' ~ evento.id) }}">
                            <button type="submit" class="btn btn-outline-danger w-100" onclick="return confirm('Tem certeza que deseja cancelar este evento?')">
                                <i class="bi bi-x-circle me-1"></i> Cancelar Evento
                            </button>
                        </form>
                        <form method="POST" action="{{ path('agenda_excluir', {id: evento.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ evento.id) }}">
                            <button type="submit" class="btn btn-danger w-100" onclick="return confirm('Tem certeza que deseja EXCLUIR permanentemente este evento?')">
                                <i class="bi bi-trash me-1"></i> Excluir Evento
                            </button>
                        </form>
                    </div>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</section>
{% endblock %}
