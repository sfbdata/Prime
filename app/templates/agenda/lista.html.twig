{% extends 'base.html.twig' %}

{% block title %}Lista de Eventos{% endblock %}

{% block body %}
<section class="content-header">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <h1 class="m-0"><i class="bi bi-list-ul me-2"></i>Lista de Eventos</h1>
        <div class="d-flex gap-2">
            <a href="{{ path('agenda_index') }}" class="btn btn-outline-primary">
                <i class="bi bi-calendar3 me-1"></i> Ver Calendário
            </a>
            <a href="{{ path('agenda_novo') }}" class="btn btn-success">
                <i class="bi bi-plus-lg me-1"></i> Novo Evento
            </a>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        {# Filtros #}
        <div class="card card-outline card-primary mb-3">
            <div class="card-header">
                <h3 class="card-title"><i class="bi bi-funnel me-1"></i> Filtros</h3>
            </div>
            <div class="card-body">
                <form method="GET" action="{{ path('agenda_lista') }}">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label for="filter_status" class="form-label">Status</label>
                            <select id="filter_status" name="status" class="form-control">
                                <option value="">Todos</option>
                                <option value="agendado" {% if statusFiltro == 'agendado' %}selected{% endif %}>Agendado</option>
                                <option value="concluido" {% if statusFiltro == 'concluido' %}selected{% endif %}>Concluído</option>
                                <option value="cancelado" {% if statusFiltro == 'cancelado' %}selected{% endif %}>Cancelado</option>
                            </select>
                        </div>
                        <div class="col-md-2 d-flex align-items-end gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-search me-1"></i> Filtrar
                            </button>
                            <a href="{{ path('agenda_lista') }}" class="btn btn-secondary">
                                <i class="bi bi-x-lg me-1"></i> Limpar
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-muted"><i class="bi bi-calendar-event me-1"></i> {{ eventos|length }} evento(s) encontrado(s)</span>
        </div>

        <div class="card">
            <div class="card-body table-responsive p-0">
                {% if eventos|length > 0 %}
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th><i class="bi bi-card-heading me-1"></i> Título</th>
                            <th><i class="bi bi-calendar-event me-1"></i> Início</th>
                            <th><i class="bi bi-calendar-check me-1"></i> Fim</th>
                            <th><i class="bi bi-geo-alt me-1"></i> Local</th>
                            <th><i class="bi bi-flag me-1"></i> Status</th>
                            <th><i class="bi bi-person me-1"></i> Criador</th>
                            <th><i class="bi bi-people me-1"></i> Participantes</th>
                            <th><i class="bi bi-gear me-1"></i> Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for evento in eventos %}
                        <tr>
                            <td>
                                <span class="badge" style="background-color: {{ evento.cor }};">&nbsp;</span>
                                {{ evento.titulo }}
                                {% if evento.diaInteiro %}
                                    <small class="text-muted">(dia inteiro)</small>
                                {% endif %}
                            </td>
                            <td>{{ evento.dataInicio|date('d/m/Y H:i') }}</td>
                            <td>{{ evento.dataFim|date('d/m/Y H:i') }}</td>
                            <td>{{ evento.local ?: '-' }}</td>
                            <td>
                                <span class="badge {{ evento.statusBadgeClass }}">{{ evento.statusLabel }}</span>
                            </td>
                            <td>{{ evento.criador.fullName }}</td>
                            <td>
                                {% if evento.participantes|length > 0 %}
                                    {{ evento.participantes|length }} pessoa(s)
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td>
                                <a href="{{ path('agenda_show', {id: evento.id}) }}" class="btn btn-sm btn-info" title="Ver">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="{{ path('agenda_editar', {id: evento.id}) }}" class="btn btn-sm btn-warning" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                {% if evento.status != 'cancelado' %}
                                <form method="POST" action="{{ path('agenda_cancelar', {id: evento.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('cancelar' ~ evento.id) }}">
                                    <button type="submit" class="btn btn-sm btn-danger" title="Cancelar" onclick="return confirm('Cancelar este evento?')">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                </form>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
                {% else %}
                <div class="p-3">
                    <div class="alert alert-info mb-0"><i class="bi bi-info-circle me-1"></i> Nenhum evento encontrado.</div>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</section>
{% endblock %}
