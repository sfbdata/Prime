{# templates/_sidebar.html.twig — Estilo PJe #}
{% set currentRoute = app.request.attributes.get('_route')|default('') %}

{# Backdrop escuro — fecha o sidebar ao clicar fora #}
<div class="sidebar-backdrop" id="sidebarBackdrop"></div>

<aside class="app-sidebar pje-sidebar" id="pjeSidebar">

    {# ── Busca rápida ── #}
    <div class="pje-sidebar-search">
        <div class="pje-search-input-group">
            <span class="pje-search-icon"><i class="fa fa-search"></i></span>
            <input type="text" id="sidebarSearchInput"
                   class="pje-search-input"
                   placeholder="Acesso rápido"
                   autocomplete="off"
                   aria-label="Acesso rápido">
        </div>
        <div class="pje-search-results" id="sidebarSearchResults" style="display:none;">
            <ul class="pje-search-list" id="sidebarSearchList"></ul>
        </div>
    </div>

    {# ── Menu principal ── #}
    <div class="sidebar-wrapper pje-menu-wrapper">
        <nav>
            <ul class="pje-menu-list">

                <li class="pje-menu-item">
                    <a href="{{ path('homepage') }}"
                       class="pje-menu-link {{ currentRoute in ['homepage','home'] ? 'active' : '' }}">
                        <i class="bi bi-house pje-nav-icon"></i>
                        <span>Home</span>
                    </a>
                </li>

                {% if can_access_module('pastas') %}
                    <li class="pje-menu-item">
                        <a href="{{ path('pasta_index') }}"
                           class="pje-menu-link {{ currentRoute starts with 'pasta_' ? 'active' : '' }}">
                            <i class="bi bi-folder pje-nav-icon"></i>
                            <span>Pastas</span>
                        </a>
                    </li>
                {% endif %}

                {% if can_access_module('clientes') %}
                    <li class="pje-menu-item">
                        <a href="{{ path('cliente_index') }}"
                           class="pje-menu-link {{ currentRoute starts with 'cliente_' ? 'active' : '' }}">
                            <i class="bi bi-people pje-nav-icon"></i>
                            <span>Clientes</span>
                        </a>
                    </li>
                {% endif %}

                {% if can_access_module('processos') %}
                    <li class="pje-menu-item">
                        <a href="{{ path('processo_index') }}"
                           class="pje-menu-link {{ currentRoute starts with 'processo_' ? 'active' : '' }}">
                            <i class="bi bi-briefcase pje-nav-icon"></i>
                            <span>Processos</span>
                        </a>
                    </li>
                {% endif %}

                {% if can_access_module('tarefas') %}
                    <li class="pje-menu-item">
                        <a href="{{ path('tarefa_minhas') }}"
                           class="pje-menu-link {{ currentRoute starts with 'tarefa_' ? 'active' : '' }}">
                            <i class="bi bi-list-check pje-nav-icon"></i>
                            <span>Minhas Tarefas</span>
                        </a>
                    </li>
                {% endif %}

                {% if can_access_module('agenda') %}
                    <li class="pje-menu-item">
                        <a href="{{ path('agenda_index') }}"
                           class="pje-menu-link {{ currentRoute starts with 'agenda_' ? 'active' : '' }}">
                            <i class="bi bi-calendar3 pje-nav-icon"></i>
                            <span>Agenda</span>
                        </a>
                    </li>
                {% endif %}

                {% if can_access_module('servicedesk') %}
                    <li class="pje-menu-item">
                        <a href="{{ path('servicedesk_meus_chamados') }}"
                           class="pje-menu-link {{ currentRoute == 'servicedesk_meus_chamados' or currentRoute == 'servicedesk_novo' ? 'active' : '' }}">
                            <i class="bi bi-headset pje-nav-icon"></i>
                            <span>Service Desk</span>
                        </a>
                    </li>
                {% endif %}

                {% if can_access_module('precadastros') %}
                    <li class="pje-menu-item">
                        <a href="{{ path('pre_cadastro_index') }}"
                           class="pje-menu-link {{ currentRoute starts with 'pre_cadastro_' ? 'active' : '' }}">
                            <i class="bi bi-person-plus pje-nav-icon"></i>
                            <span>Pré-Cadastros</span>
                        </a>
                    </li>
                {% endif %}

                {% if can_access_module('ponto') %}
                    <li class="pje-menu-item">
                        <a href="{{ path('ponto_index') }}"
                           class="pje-menu-link {{ currentRoute starts with 'ponto_' ? 'active' : '' }}">
                            <i class="bi bi-fingerprint pje-nav-icon"></i>
                            <span>Ponto Eletrônico</span>
                        </a>
                    </li>
                {% endif %}

                {# Seção ADMIN — visível se o usuário tiver qualquer permissão admin.* #}
                {% set hasAnyAdminPerm =
                    can_administer('admin.users.invite') or
                    can_administer('admin.users.manage') or
                    can_administer('admin.tenant.settings.manage') or
                    can_administer('admin.roles.manage') or
                    can_administer('admin.access_requests.approve') or
                    can_administer('admin.tarefas.manage') or
                    can_administer('admin.servicedesk.manage') or
                    can_administer('admin.ponto.manage') or
                    can_administer('admin.audit.view')
                %}
                {% if hasAnyAdminPerm %}
                    <li class="pje-menu-separator">ADMIN</li>

                    {% if can_administer('admin.users.invite') %}
                        <li class="pje-menu-item">
                            <a href="{{ path('invite_user') }}"
                               class="pje-menu-link {{ currentRoute == 'invite_user' ? 'active' : '' }}">
                                <i class="bi bi-envelope pje-nav-icon"></i>
                                <span>Convidar Usuários</span>
                            </a>
                        </li>
                    {% endif %}

                    {% if can_administer('admin.users.manage') %}
                        <li class="pje-menu-item">
                            <a href="{{ path('app_tenant_users', {'id': app.user.tenant.id}) }}"
                               class="pje-menu-link {{ currentRoute == 'app_tenant_users' ? 'active' : '' }}">
                                <i class="bi bi-people-fill pje-nav-icon"></i>
                                <span>Funcionários</span>
                            </a>
                        </li>
                    {% endif %}

                    {% if can_administer('admin.tenant.settings.manage') %}
                        <li class="pje-menu-item">
                            <a href="{{ path('app_tenant_show', {'id': app.user.tenant.id}) }}"
                               class="pje-menu-link {{ currentRoute == 'app_tenant_show' ? 'active' : '' }}">
                                <i class="bi bi-building-gear pje-nav-icon"></i>
                                <span>Meu Escritório</span>
                            </a>
                        </li>
                    {% endif %}

                    {% if can_administer('admin.roles.manage') %}
                        <li class="pje-menu-item">
                            <a href="{{ path('app_tenant_role_index', {'tenantId': app.user.tenant.id}) }}"
                               class="pje-menu-link {{ currentRoute starts with 'app_tenant_role_' ? 'active' : '' }}">
                                <i class="bi bi-shield-lock pje-nav-icon"></i>
                                <span>Perfis</span>
                            </a>
                        </li>
                    {% endif %}

                    {% if can_administer('admin.access_requests.approve') %}
                        <li class="pje-menu-item">
                            <a href="{{ path('app_access_request_index') }}"
                               class="pje-menu-link {{ currentRoute starts with 'app_access_request_' ? 'active' : '' }}">
                                <i class="bi bi-key pje-nav-icon"></i>
                                <span>Solicitações de Acesso</span>
                            </a>
                        </li>
                    {% endif %}

                    {% if can_administer('admin.tarefas.manage') %}
                        <li class="pje-menu-item">
                            <a href="{{ path('tarefa_admin_index') }}"
                               class="pje-menu-link {{ currentRoute starts with 'tarefa_admin_' ? 'active' : '' }}">
                                <i class="bi bi-kanban pje-nav-icon"></i>
                                <span>Gestão de Tarefas</span>
                            </a>
                        </li>
                    {% endif %}

                    {% if can_administer('admin.servicedesk.manage') %}
                        <li class="pje-menu-item">
                            <a href="{{ path('servicedesk_index') }}"
                               class="pje-menu-link {{ currentRoute == 'servicedesk_index' ? 'active' : '' }}">
                                <i class="bi bi-headset pje-nav-icon"></i>
                                <span>Service Desk (TI)</span>
                            </a>
                        </li>
                    {% endif %}

                    {% if can_administer('admin.ponto.manage') %}
                        <li class="pje-menu-item">
                            <a href="{{ path('app_tenant_sedes', {'id': app.user.tenant.id}) }}"
                               class="pje-menu-link {{ currentRoute == 'app_tenant_sedes' ? 'active' : '' }}">
                                <i class="bi bi-geo-alt pje-nav-icon"></i>
                                <span>Sedes (Ponto)</span>
                            </a>
                        </li>
                    {% endif %}

                    {% if can_administer('admin.audit.view') %}
                        <li class="pje-menu-item">
                            <a href="{{ path('audit_log_index') }}"
                               class="pje-menu-link {{ currentRoute starts with 'audit_log_' ? 'active' : '' }}">
                                <i class="bi bi-shield-check pje-nav-icon"></i>
                                <span>Trilha de Auditoria</span>
                            </a>
                        </li>
                    {% endif %}
                {% endif %}

            </ul>
        </nav>
    </div>

</aside>

<script>
(function () {
    'use strict';

    var sidebar  = document.getElementById('pjeSidebar');
    var backdrop = document.getElementById('sidebarBackdrop');

    function openSidebar() {
        sidebar.classList.add('sidebar-open');
        backdrop.classList.add('active');
    }

    function closeSidebar() {
        sidebar.classList.remove('sidebar-open');
        backdrop.classList.remove('active');
    }

    function toggleSidebar() {
        sidebar.classList.contains('sidebar-open') ? closeSidebar() : openSidebar();
    }

    document.addEventListener('DOMContentLoaded', function () {

        // ── Busca rápida ──────────────────────────────────────────
        var input   = document.getElementById('sidebarSearchInput');
        var results = document.getElementById('sidebarSearchResults');
        var list    = document.getElementById('sidebarSearchList');

        var links = Array.from(document.querySelectorAll('.pje-menu-link')).map(function (a) {
            return {
                label: a.querySelector('span') ? a.querySelector('span').textContent.trim() : '',
                href:  a.getAttribute('href')
            };
        }).filter(function (l) { return l.label && l.href && l.href !== '#'; });

        input.addEventListener('input', function () {
            var q = this.value.trim().toLowerCase();
            list.innerHTML = '';
            if (!q) { results.style.display = 'none'; return; }
            var found = links.filter(function (l) { return l.label.toLowerCase().includes(q); });
            if (found.length === 0) {
                list.innerHTML = '<li class="pje-search-empty">Nenhum resultado</li>';
            } else {
                found.forEach(function (l) {
                    var li = document.createElement('li');
                    li.innerHTML = '<a href="' + l.href + '">' + l.label + '</a>';
                    list.appendChild(li);
                });
            }
            results.style.display = 'block';
        });

        document.addEventListener('click', function (e) {
            var searchEl = document.querySelector('.pje-sidebar-search');
            if (searchEl && !searchEl.contains(e.target)) {
                results.style.display = 'none';
            }
        });

        // ── Botão hamburger ───────────────────────────────────────
        var btn = document.getElementById('sidebarToggleBtn');
        if (btn) {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                toggleSidebar();
            });
        }

        // ── Backdrop fecha o sidebar ──────────────────────────────
        backdrop.addEventListener('click', closeSidebar);

        // ── Links do menu fecham o sidebar ────────────────────────
        document.querySelectorAll('.pje-menu-link').forEach(function (link) {
            link.addEventListener('click', closeSidebar);
        });

        // ── Escape fecha o sidebar ────────────────────────────────
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closeSidebar();
        });

        // ── MutationObserver: remove sidebar-open que o AdminLTE
        //    possa reinjetar no body depois do carregamento ─────────
        var observer = new MutationObserver(function (mutations) {
            mutations.forEach(function (m) {
                if (m.attributeName === 'class' &&
                    document.body.classList.contains('sidebar-open') &&
                    !sidebar.classList.contains('sidebar-open')) {
                    document.body.classList.remove('sidebar-open');
                }
            });
        });
        observer.observe(document.body, { attributes: true });

    });
})();
</script>
