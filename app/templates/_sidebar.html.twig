{# templates/_sidebar.html.twig - AdminLTE 4 #}
{% set currentRoute = app.request.attributes.get('_route')|default('') %}
<aside class="app-sidebar bg-body-secondary shadow" data-bs-theme="dark">
    {# Sidebar Brand #}
    <div class="sidebar-brand">
        <a href="{{ path('homepage') }}" class="brand-link">
            <span class="brand-text fw-light">JusPrime</span>
        </a>
    </div>
    
    {# Sidebar Wrapper #}
    <div class="sidebar-wrapper">
        {# Sidebar Menu #}
        <nav class="mt-2">
            <ul class="nav sidebar-menu flex-column" data-lte-toggle="treeview" role="navigation" data-accordion="false">
                <li class="nav-item">
                    <a class="nav-link {{ currentRoute in ['homepage', 'home'] ? 'active' : '' }}" href="{{ path('homepage') }}">
                        <i class="nav-icon bi bi-house"></i>
                        <p>Home</p>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ currentRoute starts with 'cliente_' ? 'active' : '' }}" href="{{ path('cliente_index') }}">
                        <i class="nav-icon bi bi-people"></i>
                        <p>Clientes</p>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ currentRoute starts with 'contrato_' ? 'active' : '' }}" href="{{ path('contrato_index') }}">
                        <i class="nav-icon bi bi-file-earmark-text"></i>
                        <p>Contratos</p>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ currentRoute starts with 'processo_' ? 'active' : '' }}" href="{{ path('processo_index') }}">
                        <i class="nav-icon bi bi-briefcase"></i>
                        <p>Processos</p>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ currentRoute starts with 'tarefa_' ? 'active' : '' }}" href="{{ path('tarefa_minhas') }}">
                        <i class="nav-icon bi bi-list-check"></i>
                        <p>Minhas Tarefas</p>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ currentRoute starts with 'agenda_' ? 'active' : '' }}" href="{{ path('agenda_index') }}">
                        <i class="nav-icon bi bi-calendar3"></i>
                        <p>Agenda</p>
                    </a>
                </li>

                {% if 'ROLE_COMERCIAL' in app.user.roles %}
                    <li class="nav-item">
                        <a class="nav-link {{ currentRoute starts with 'pre_cadastro_' ? 'active' : '' }}" href="{{ path('pre_cadastro_index') }}">
                            <i class="nav-icon bi bi-person-plus"></i>
                            <p>Pré-Cadastros</p>
                        </a>
                    </li>
                {% endif %}

                {% if 'ROLE_SUPER_ADMIN' in app.user.roles %}
                    <li class="nav-header">SUPER-ADMIN</li>
                    <li class="nav-item">
                        <a class="nav-link {{ currentRoute starts with 'app_tenant_' ? 'active' : '' }}" href="{{ path('app_tenant_index') }}">
                            <i class="nav-icon bi bi-building"></i>
                            <p>Tenants</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ currentRoute == 'app_tenant_new' ? 'active' : '' }}" href="{{ path('app_tenant_new') }}">
                            <i class="nav-icon bi bi-plus-square"></i>
                            <p>Novo Tenant</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ currentRoute starts with 'audit_log_' ? 'active' : '' }}" href="{{ path('audit_log_index') }}">
                            <i class="nav-icon bi bi-shield-check"></i>
                            <p>Trilha de Auditoria</p>
                        </a>
                    </li>
                {% endif %}

                {% if 'ROLE_ADMIN' in app.user.roles %}
                    <li class="nav-header">ADMIN</li>
                    <li class="nav-item">
                        <a class="nav-link {{ currentRoute == 'invite_user' ? 'active' : '' }}" href="{{ path('invite_user') }}">
                            <i class="nav-icon bi bi-envelope"></i>
                            <p>Convidar Usuários</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ currentRoute == 'app_tenant_users' ? 'active' : '' }}" href="{{ path('app_tenant_users', {'id': app.user.tenant.id}) }}">
                            <i class="nav-icon bi bi-people-fill"></i>
                            <p>Funcionários</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ currentRoute == 'app_tenant_show' ? 'active' : '' }}" href="{{ path('app_tenant_show', {'id': app.user.tenant.id}) }}">
                            <i class="nav-icon bi bi-building-gear"></i>
                            <p>Meu Escritório</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ currentRoute starts with 'tarefa_admin_' ? 'active' : '' }}" href="{{ path('tarefa_admin_index') }}">
                            <i class="nav-icon bi bi-kanban"></i>
                            <p>Gestão de Tarefas</p>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ currentRoute starts with 'audit_log_' ? 'active' : '' }}" href="{{ path('audit_log_index') }}">
                            <i class="nav-icon bi bi-shield-check"></i>
                            <p>Trilha de Auditoria</p>
                        </a>
                    </li>
                {% endif %}
            </ul>
        </nav>
    </div>
</aside>
