{% extends 'base.html.twig' %}

{% block title %}Processos Judiciais{% endblock %}

{% block body %}
<section class="content-header">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <h1 class="m-0">Processos Judiciais</h1>
        <div class="d-flex gap-2">
            <a href="{{ path('contrato_index') }}" class="btn btn-secondary">← Voltar aos Contratos</a>
            <a href="{{ path('processo_new') }}" class="btn btn-success">Cadastrar Processo</a>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        {# Filtros #}
        <div class="card card-outline card-primary mb-3">
            <div class="card-header">
                <h3 class="card-title"><i class="bi bi-funnel me-1"></i> Filtros</h3>
                <div class="card-tools">
                    <button type="button" class="btn btn-tool" data-bs-toggle="collapse" data-bs-target="#filtrosProcesso">
                        <i class="bi bi-dash-lg"></i>
                    </button>
                </div>
            </div>
            <div class="collapse show" id="filtrosProcesso">
                <div class="card-body">
                    <form method="GET" action="{{ path('processo_index') }}" id="formFiltrosProcesso">
                        <div class="row g-3">
                            <div class="col-md-2">
                                <label for="filter_numero" class="form-label">Nº Processo</label>
                                <select id="filter_numero" name="numero_processo" class="form-control select2-filter">
                                    <option value="">Todos</option>
                                    {% for numero in numerosProcesso|keys %}
                                        <option value="{{ numero }}" {% if filters.numero_processo == numero %}selected{% endif %}>{{ numero }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label for="filter_tribunal" class="form-label">Tribunal</label>
                                <select id="filter_tribunal" name="tribunal" class="form-control select2-filter">
                                    <option value="">Todos</option>
                                    {% for tribunal in tribunais|keys %}
                                        <option value="{{ tribunal }}" {% if filters.tribunal == tribunal %}selected{% endif %}>{{ tribunal }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label for="filter_classe" class="form-label">Classe</label>
                                <select id="filter_classe" name="classe" class="form-control select2-filter">
                                    <option value="">Todas</option>
                                    {% for classe in classes|keys %}
                                        <option value="{{ classe }}" {% if filters.classe == classe %}selected{% endif %}>{{ classe }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label for="filter_assunto" class="form-label">Assunto</label>
                                <select id="filter_assunto" name="assunto" class="form-control select2-filter">
                                    <option value="">Todos</option>
                                    {% for assunto in assuntos|keys %}
                                        <option value="{{ assunto }}" {% if filters.assunto == assunto %}selected{% endif %}>{{ assunto }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label for="filter_situacao" class="form-label">Situação</label>
                                <select id="filter_situacao" name="situacao" class="form-control select2-filter">
                                    <option value="">Todas</option>
                                    <option value="EM_ANDAMENTO" {% if filters.situacao == 'EM_ANDAMENTO' %}selected{% endif %}>Em Andamento</option>
                                    <option value="ENCERRADO" {% if filters.situacao == 'ENCERRADO' %}selected{% endif %}>Encerrado</option>
                                    <option value="SUSPENSO" {% if filters.situacao == 'SUSPENSO' %}selected{% endif %}>Suspenso</option>
                                    <option value="ARQUIVADO" {% if filters.situacao == 'ARQUIVADO' %}selected{% endif %}>Arquivado</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label for="filter_status_docs" class="form-label">Status Docs</label>
                                <select id="filter_status_docs" name="status_documentos" class="form-control select2-filter">
                                    <option value="">Todos</option>
                                    <option value="{{ constant('App\\Entity\\Processo\\Processo::STATUS_DOCUMENTOS_APTO') }}" {% if filters.status_documentos == constant('App\\Entity\\Processo\\Processo::STATUS_DOCUMENTOS_APTO') %}selected{% endif %}>Apto para Protocolar</option>
                                    <option value="{{ constant('App\\Entity\\Processo\\Processo::STATUS_DOCUMENTOS_PENDENTE') }}" {% if filters.status_documentos == constant('App\\Entity\\Processo\\Processo::STATUS_DOCUMENTOS_PENDENTE') %}selected{% endif %}>Pendente de Documentação</option>
                                </select>
                            </div>
                        </div>
                        <div class="row mt-3">
                            <div class="col-12 d-flex gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-search me-1"></i> Filtrar
                                </button>
                                <a href="{{ path('processo_index') }}" class="btn btn-secondary">
                                    <i class="bi bi-x-lg me-1"></i> Limpar
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-muted"><i class="bi bi-list-ul me-1"></i> {{ processos|length }} resultado(s) encontrado(s)</span>
        </div>

    {% if processos|length > 0 %}
    <div class="card">
        <div class="card-body table-responsive p-0">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th><i class="bi bi-hash me-1"></i> Número do Processo</th>
                        <th><i class="bi bi-building me-1"></i> Tribunal</th>
                        <th><i class="bi bi-bookmark me-1"></i> Classe</th>
                        <th><i class="bi bi-chat-left-text me-1"></i> Assunto</th>
                        <th><i class="bi bi-flag me-1"></i> Situação</th>
                        <th><i class="bi bi-check2-square me-1"></i> Status Documentos</th>
                        <th><i class="bi bi-file-earmark-text me-1"></i> Contrato</th>
                        <th><i class="bi bi-gear me-1"></i> Ações</th>
                    </tr>
                </thead>
                <tbody>
                    {% for processo in processos %}
                        <tr>
                            <td>{{ processo.numeroProcesso }}</td>
                            <td>{{ processo.siglaTribunal }}</td>
                            <td>{{ processo.classeProcessual }}</td>
                            <td>{{ processo.assuntoProcessual }}</td>
                            <td>
                                <span class="badge {% if processo.situacaoProcesso == 'EM_ANDAMENTO' %}text-bg-warning{% elseif processo.situacaoProcesso == 'ENCERRADO' %}text-bg-danger{% else %}text-bg-secondary{% endif %}">
                                    {{ processo.situacaoProcesso|replace({'_': ' '}) }}
                                </span>
                            </td>
                            <td>
                                <span class="badge {{ processo.statusDocumentos == constant('App\\Entity\\Processo\\Processo::STATUS_DOCUMENTOS_APTO') ? 'text-bg-success' : 'text-bg-warning' }}">
                                    {{ processo.statusDocumentos == constant('App\\Entity\\Processo\\Processo::STATUS_DOCUMENTOS_APTO') ? 'Apto para Protocolar' : 'Pendente de Documentação' }}
                                </span>
                            </td>
                            <td>
                                {% if processo.contrato %}
                                    <a href="{{ path('contrato_show', {id: processo.contrato.id}) }}">
                                        {{ processo.contrato.nomeArquivo }}
                                    </a>
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td>
                                <a href="{{ path('processo_show', {id: processo.id}) }}" class="btn btn-sm btn-info">Ver</a>
                                <a href="{{ path('processo_edit', {id: processo.id}) }}" class="btn btn-sm btn-warning">Editar</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% else %}
    <div class="alert alert-info mb-0">
        Nenhum processo encontrado. <a href="{{ path('processo_new') }}">Criar novo processo</a>
    </div>
    {% endif %}
    </div>
</section>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
$(document).ready(function() {
    $('.select2-filter').select2({
        placeholder: 'Selecione...',
        allowClear: true,
        width: '100%'
    });
});
</script>
{% endblock %}
