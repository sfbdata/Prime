{% extends 'base.html.twig' %}

{% block title %}Detalhes do Processo{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="mb-3">
        <a href="{{ path('processo_index') }}" class="btn btn-secondary">← Voltar aos Processos</a>
    </div>

    <div class="card">
        <div class="card-header">
            <h2>{{ processo.numeroProcesso }}</h2>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <h5>Informações do Processo</h5>
                    <p><strong>Tribunal:</strong> {{ processo.siglaTribunal }}</p>
                    <p><strong>Órgão Julgador:</strong> {{ processo.orgaoJulgador }}</p>
                    <p><strong>Classe Processual:</strong> {{ processo.classeProcessual }}</p>
                    <p><strong>Assunto:</strong> {{ processo.assuntoProcessual }}</p>
                    <p><strong>Situação:</strong>
                        <span class="badge {% if processo.situacaoProcesso == 'EM_ANDAMENTO' %}bg-warning{% elseif processo.situacaoProcesso == 'ENCERRADO' %}bg-danger{% else %}bg-secondary{% endif %}">
                            {{ processo.situacaoProcesso|replace({'_': ' '}) }}
                        </span>
                    </p>
                    <p><strong>Instância:</strong> {{ processo.instancia }}</p>
                </div>
                <div class="col-md-6">
                    <h5>Datas</h5>
                    <p><strong>Distribuição:</strong> {% if processo.dataDistribuicao %}{{ processo.dataDistribuicao|date('d/m/Y') }}{% else %}-{% endif %}</p>
                    <p><strong>Baixa:</strong> {% if processo.dataBaixa %}{{ processo.dataBaixa|date('d/m/Y') }}{% else %}-{% endif %}</p>
                    <p><strong>Última Atualização:</strong> {% if processo.dataAtualizacao %}{{ processo.dataAtualizacao|date('d/m/Y H:i') }}{% else %}-{% endif %}</p>
                </div>
            </div>

            {% if processo.contrato %}
            <div class="mt-3 p-3 bg-light rounded">
                <strong>Contrato Associado:</strong>
                <span class="me-2">{{ processo.contrato.nomeArquivo }}</span>
                <a href="{{ path('contrato_show', {id: processo.contrato.id}) }}" class="btn btn-sm btn-outline-primary">Visualizar detalhes do contrato</a>
            </div>
            {% endif %}

            <hr>

            <div class="mb-3">
                <h5>Histórico de Tarefas (ordem decrescente)</h5>
                {% if historicoTarefas|length > 0 %}
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Título</th>
                                <th>Usuário (atribuído)</th>
                                <th>Status Atual</th>
                                <th>Data de Criação</th>
                                <th>Data da Última Revisão</th>
                                <th>Data de Conclusão Final</th>
                                <th>Tempo Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in historicoTarefas %}
                                <tr>
                                    <td><a href="{{ path('tarefa_show', {id: item.tarefaId}) }}">{{ item.titulo }}</a></td>
                                    <td>{{ item.usuarios }}</td>
                                    <td>{{ item.statusAtual|replace({'_': ' '})|upper }}</td>
                                    <td>{{ item.dataCriacao|date('d/m/Y H:i') }}</td>
                                    <td>{% if item.dataUltimaRevisao %}{{ item.dataUltimaRevisao|date('d/m/Y H:i') }}{% else %}-{% endif %}</td>
                                    <td>{% if item.dataConclusaoFinal %}{{ item.dataConclusaoFinal|date('d/m/Y H:i') }}{% else %}-{% endif %}</td>
                                    <td>
                                        {% if item.tempoTotalSegundos is not null %}
                                            {% set horas = item.tempoTotalSegundos // 3600 %}
                                            {% set minutos = (item.tempoTotalSegundos % 3600) // 60 %}
                                            {{ horas }}h {{ '%02d'|format(minutos) }}min
                                        {% else %}
                                            -
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <div class="alert alert-info mb-0">Não há tarefas vinculadas a este processo.</div>
                {% endif %}
            </div>

            <hr>

            <div class="mb-3">
                <h5>Partes do Processo</h5>
                {% if processo.partes|length > 0 %}
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Tipo</th>
                                <th>Nome</th>
                                <th>Documento</th>
                                <th>Papel</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for parte in processo.partes %}
                                <tr>
                                    <td>{{ parte.tipo }}</td>
                                    <td>{{ parte.nome }}</td>
                                    <td>{{ parte.documento ?: '-' }}</td>
                                    <td>{{ parte.papel ?: '-' }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <div class="alert alert-info mb-0">Nenhuma parte cadastrada.</div>
                {% endif %}
            </div>

            <hr>

            <div class="mb-3">
                <h5>Movimentações</h5>
                {% if processo.movimentacoes|length > 0 %}
                    <div style="max-height: 360px; overflow-y: auto; border: 1px solid #dee2e6; border-radius: 0.25rem;">
                        <table class="table table-sm table-bordered mb-0">
                            <thead class="table-light" style="position: sticky; top: 0; z-index: 1;">
                                <tr>
                                    <th>Data</th>
                                    <th>Descrição</th>
                                    <th>Tipo</th>
                                    <th>Órgão</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for mov in processo.movimentacoes %}
                                    <tr>
                                        <td>{% if mov.dataMovimentacao %}{{ mov.dataMovimentacao|date('d/m/Y') }}{% else %}-{% endif %}</td>
                                        <td>{{ mov.descricao }}</td>
                                        <td>{{ mov.tipo ?: '-' }}</td>
                                        <td>{{ mov.orgao ?: '-' }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="alert alert-info mb-0">Nenhuma movimentação cadastrada.</div>
                {% endif %}
            </div>

            <hr>

            <div class="d-flex justify-content-end gap-2">
                <a href="{{ path('processo_edit', {id: processo.id}) }}" class="btn btn-warning">Editar Processo</a>
                <form method="post" action="{{ path('processo_delete', {id: processo.id}) }}" onsubmit="return confirm('Tem certeza que deseja excluir este processo?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_processo_' ~ processo.id) }}">
                    <button type="submit" class="btn btn-danger">Excluir Processo</button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
