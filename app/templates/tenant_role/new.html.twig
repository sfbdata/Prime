{% extends 'base.html.twig' %}

{% block title %}Novo Perfil{% endblock %}

{% block body %}
<section class="content-header">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <h1 class="m-0"><i class="bi bi-shield-plus me-2"></i>Novo Perfil</h1>
        <a href="{{ path('app_tenant_role_index', {tenantId: tenantId}) }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i> Voltar
        </a>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-body">
                {% include 'tenant_role/_form.html.twig' with {
                    form: form,
                    allPermissions: allPermissions,
                    currentCodes: []
                } %}
            </div>
            <div class="card-footer d-flex justify-content-end gap-2">
                <a href="{{ path('app_tenant_role_index', {tenantId: tenantId}) }}" class="btn btn-secondary">
                    Cancelar
                </a>
                <button type="submit" form="{{ form.vars.id }}" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i> Salvar Perfil
                </button>
            </div>
        </div>
    </div>
</section>
{% endblock %}

