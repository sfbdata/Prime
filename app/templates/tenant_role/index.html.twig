{% extends 'base.html.twig' %}

{% block title %}Perfis do Escritório{% endblock %}

{% block body %}
<section class="content-header">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <h1 class="m-0"><i class="bi bi-shield-lock me-2"></i>Perfis do Escritório</h1>
        <div class="d-flex gap-2">
            <a href="{{ path('app_tenant_show', {id: tenantId}) }}" class="btn btn-secondary">
                <i class="bi bi-arrow-left me-1"></i> Voltar
            </a>
            <a href="{{ path('app_tenant_role_new', {tenantId: tenantId}) }}" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i> Novo Perfil
            </a>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'success' ? 'success' : (label == 'error' ? 'danger' : 'warning') }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="card">
            <div class="card-body table-responsive p-0">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th><i class="bi bi-shield-check me-1"></i> Nome</th>
                            <th><i class="bi bi-card-text me-1"></i> Descrição</th>
                            <th class="text-center"><i class="bi bi-key me-1"></i> Permissões</th>
                            <th class="text-center"><i class="bi bi-people me-1"></i> Usuários</th>
                            <th class="text-center"><i class="bi bi-lock me-1"></i> Sistema</th>
                            <th><i class="bi bi-gear me-1"></i> Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for role in roles %}
                            <tr>
                                <td>
                                    <strong>{{ role.name }}</strong>
                                    {% if role.isSystem %}
                                        <span class="badge text-bg-info ms-1" title="Perfil protegido">Sistema</span>
                                    {% endif %}
                                </td>
                                <td class="text-muted small">{{ role.description ?? '—' }}</td>
                                <td class="text-center">
                                    <span class="badge text-bg-secondary">{{ role.tenantRolePermissions|length }}</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge text-bg-secondary">{{ role.users|length }}</span>
                                </td>
                                <td class="text-center">
                                    {% if role.isSystem %}
                                        <i class="bi bi-lock-fill text-warning" title="Não pode ser excluído"></i>
                                    {% else %}
                                        <i class="bi bi-unlock text-muted"></i>
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="acoes-grupo">
                                        <a href="{{ path('app_tenant_role_edit', {tenantId: tenantId, id: role.id}) }}"
                                           class="btn-action btn-action-edit"
                                           title="Editar perfil"
                                           aria-label="Editar perfil">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        {% if not role.isSystem %}
                                            <form method="post"
                                                  action="{{ path('app_tenant_role_delete', {tenantId: tenantId, id: role.id}) }}"
                                                  class="d-inline"
                                                  onsubmit="return confirm('Excluir o perfil \'{{ role.name }}\'? Usuários vinculados perderão o perfil.');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete_role_' ~ role.id) }}">
                                                <button class="btn-action btn-action-delete"
                                                        title="Excluir perfil"
                                                        aria-label="Excluir perfil">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="text-center text-muted py-3">Nenhum perfil encontrado.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</section>
{% endblock %}
