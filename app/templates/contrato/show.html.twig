{% extends 'base.html.twig' %}

{% block title %}Detalhes do Contrato{% endblock %}

{% block body %}
<section class="content-header">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <h1 class="m-0">Detalhes do Contrato</h1>
        <a href="{{ path('contrato_index') }}" class="btn btn-secondary">← Voltar aos Contratos</a>
    </div>
</section>

<section class="content">
<div class="container-fluid">
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">{{ contrato.nomeArquivo }}</h3>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-6">
                    <h5>Informações do Contrato</h5>
                    <p>
                        <strong>Status:</strong>
                        {% if contrato.status == 'ATIVO' %}
                            <span class="badge bg-success">ATIVO</span>
                        {% else %}
                            <span class="badge bg-danger">INATIVO</span>
                        {% endif %}
                    </p>
                    <div class="mb-3">
                        <strong>Chave de status:</strong>
                        <form method="post" action="{{ path('contrato_toggle_status', {id: contrato.id}) }}" class="mt-1">
                            <input type="hidden" name="_token" value="{{ csrf_token('toggle_status_' ~ contrato.id) }}">
                            <div class="form-check form-switch">
                                <input
                                    class="form-check-input"
                                    type="checkbox"
                                    role="switch"
                                    name="status_ativo"
                                    id="statusSwitch"
                                    onchange="this.form.submit()"
                                    {% if contrato.status == 'ATIVO' %}checked{% endif %}
                                >
                                <label class="form-check-label" for="statusSwitch">
                                    {% if contrato.status == 'ATIVO' %}
                                        ATIVO
                                    {% else %}
                                        INATIVO
                                    {% endif %}
                                </label>
                            </div>
                        </form>
                    </div>
                    <p>
                        <strong>Data de início:</strong>
                        {% if contrato.dataInicio %}
                            {{ contrato.dataInicio|date('d/m/Y') }}
                        {% else %}
                            -
                        {% endif %}
                    </p>
                    <p>
                        <strong>Valor total:</strong>
                        {% if contrato.valorTotal %}
                            R$ {{ contrato.valorTotal|number_format(2, ',', '.') }}
                        {% else %}
                            -
                        {% endif %}
                    </p>
                    <p>
                        <strong>Criado em:</strong>
                        {% if contrato.criadoAt %}
                            {{ contrato.criadoAt|date('d/m/Y \\à\\s H:i') }}
                        {% else %}
                            -
                        {% endif %}
                    </p>
                    <p>
                        <strong>Modificado em:</strong>
                        {% if contrato.modificadoEm %}
                            {{ contrato.modificadoEm|date('d/m/Y \\à\\s H:i') }}
                        {% else %}
                            -
                        {% endif %}
                    </p>
                </div>
                <div class="col-md-6">
                    <h5>Ações</h5>
                    <a href="{{ contrato.caminhoArquivo }}" class="btn btn-primary" target="_blank">
                        <i class="bi bi-download"></i> Baixar Contrato
                    </a>
                </div>
            </div>

            <hr>

            <div class="mb-3">
                <h5>Clientes Associados</h5>
                <div class="mb-3">
                    <button class="btn btn-success" type="button" data-bs-toggle="collapse" data-bs-target="#associarClienteCollapse" aria-expanded="false" aria-controls="associarClienteCollapse">
                        Associar Cliente
                    </button>
                </div>
                <div class="collapse" id="associarClienteCollapse">
                    <div class="card mb-3 border-0 bg-light">
                        <div class="card-body">
                            <h6 class="mb-2">Adicionar Cliente Associado</h6>
                            {% if clientesNaoAssociados|length > 0 %}
                                <form method="post" action="{{ path('contrato_associar_cliente', {id: contrato.id}) }}" class="row g-2 align-items-end">
                                    <input type="hidden" name="_token" value="{{ csrf_token('associar_cliente_' ~ contrato.id) }}">
                                    <div class="col-md-9">
                                        <label for="clienteSelect" class="form-label">Cliente</label>
                                        <select id="clienteSelect" name="cliente_id" class="form-select" required>
                                            <option value="">Selecione um cliente</option>
                                            {% for cliente in clientesNaoAssociados %}
                                                <option value="{{ cliente.id }}">
                                                    {% if cliente.cpf is defined %}
                                                        {{ cliente.nomeCompleto }} - CPF: {{ cliente.cpf }}
                                                    {% else %}
                                                        {{ cliente.razaoSocial }} - CNPJ: {{ cliente.cnpj }}
                                                    {% endif %}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <button type="submit" class="btn btn-success w-100">Associar Cliente</button>
                                    </div>
                                </form>
                            {% else %}
                                <span class="text-muted">Todos os clientes já estão associados a este contrato.</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
                {% if contrato.clientes|length > 0 %}
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Nome/Razão Social</th>
                                <th>CPF/CNPJ</th>
                                <th>Tipo</th>
                                <th>Telefone</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for cliente in contrato.clientes %}
                                <tr>
                                    <td>
                                        {% if cliente.cpf is defined %}
                                            {{ cliente.nomeCompleto }}
                                        {% else %}
                                            {{ cliente.razaoSocial }}
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if cliente.cpf is defined %}
                                            {{ cliente.cpf }}
                                        {% else %}
                                            {{ cliente.cnpj }}
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if cliente.cpf is defined %}
                                            <span class="badge bg-info">Pessoa Física</span>
                                        {% else %}
                                            <span class="badge bg-warning">Pessoa Jurídica</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ cliente.telefoneCelular ?: '-' }}</td>
                                    <td>
                                        <a href="{{ path('cliente_show', {id: cliente.id}) }}" class="btn btn-sm btn-info">Ver Cliente</a>
                                        <form method="post" action="{{ path('contrato_desassociar_cliente', {id: contrato.id, clienteId: cliente.id}) }}" class="d-inline" onsubmit="return confirm('Tem certeza que deseja remover este cliente do contrato?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('desassociar_cliente_' ~ contrato.id ~ '_' ~ cliente.id) }}">
                                            <button type="submit" class="btn btn-sm btn-danger">Excluir</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <div class="alert alert-info">
                        Nenhum cliente associado a este contrato.
                    </div>
                {% endif %}
            </div>

            <hr>

            <div class="mb-3">
                <h5>Processos Judiciais Associados</h5>
                {% if contrato.processos|length > 0 %}
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Número do Processo</th>
                                <th>Órgão Julgador</th>
                                <th>Status</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for processo in contrato.processos %}
                                <tr>
                                    <td>{{ processo.numeroProcesso }}</td>
                                    <td>{{ processo.orgaoJulgador }}</td>
                                    <td>
                                        <span class="badge bg-secondary">{{ processo.situacaoProcesso|replace({'_': ' '}) }}</span>
                                    </td>
                                    <td>
                                        <a href="{{ path('processo_show', {id: processo.id}) }}" class="btn btn-sm btn-info">Ver Processo</a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <div class="alert alert-info">
                        Nenhum processo judicial associado a este contrato.
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
</section>

<script>
    $(document).ready(function () {
        const $clienteSelect = $('#clienteSelect');
        if ($clienteSelect.length) {
            $clienteSelect.select2({
                placeholder: 'Pesquisar cliente...',
                width: '100%'
            });

            $('#associarClienteCollapse').on('shown.bs.collapse', function () {
                $clienteSelect.select2('close');
            });
        }
    });
</script>
{% endblock %}
