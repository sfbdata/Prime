{% extends 'base.html.twig' %}

{% block title %}Contratos{% endblock %}

{% block body %}
<section class="content-header">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <h1 class="m-0">Contratos</h1>
        <a href="{{ path('cliente_index') }}" class="btn btn-secondary">← Voltar aos Clientes</a>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        {# Filtros #}
        <div class="card card-outline card-primary mb-3">
            <div class="card-header" style="cursor: pointer;" data-bs-toggle="collapse" data-bs-target="#filtrosContrato">
                <h3 class="card-title"><i class="bi bi-funnel me-1"></i> Filtros</h3>
                <div class="card-tools">
                    <button type="button" class="btn btn-tool">
                        <i class="bi bi-chevron-down"></i>
                    </button>
                </div>
            </div>
            <div class="collapse" id="filtrosContrato">
                <div class="card-body">
                    <form method="GET" action="{{ path('contrato_index') }}" id="formFiltrosContrato">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label for="filter_cliente" class="form-label">Cliente Associado</label>
                                <select id="filter_cliente" name="cliente_id" class="form-control select2-filter">
                                    <option value="">Todos</option>
                                    {% for cliente in clientes %}
                                        <option value="{{ cliente.id }}" {% if filters.cliente_id == (cliente.id ~ '') %}selected{% endif %}>
                                            {% if cliente.cpf is defined %}
                                                {{ cliente.nomeCompleto }} ({{ cliente.cpf }})
                                            {% else %}
                                                {{ cliente.razaoSocial }} ({{ cliente.cnpj }})
                                            {% endif %}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label for="filter_data_inicio_de" class="form-label">Data Início (de)</label>
                                <input type="date" id="filter_data_inicio_de" name="data_inicio_de" class="form-control" value="{{ filters.data_inicio_de }}">
                            </div>
                            <div class="col-md-2">
                                <label for="filter_data_inicio_ate" class="form-label">Data Início (até)</label>
                                <input type="date" id="filter_data_inicio_ate" name="data_inicio_ate" class="form-control" value="{{ filters.data_inicio_ate }}">
                            </div>
                            <div class="col-md-2">
                                <label for="filter_valor_min" class="form-label">Valor Mínimo</label>
                                <input type="number" id="filter_valor_min" name="valor_min" class="form-control" step="0.01" min="0" placeholder="R$ 0,00" value="{{ filters.valor_min }}">
                            </div>
                            <div class="col-md-2">
                                <label for="filter_valor_max" class="form-label">Valor Máximo</label>
                                <input type="number" id="filter_valor_max" name="valor_max" class="form-control" step="0.01" min="0" placeholder="R$ 0,00" value="{{ filters.valor_max }}">
                            </div>
                            <div class="col-md-1 d-flex align-items-end gap-2">
                                <button type="submit" class="btn btn-primary" title="Filtrar">
                                    <i class="bi bi-search"></i>
                                </button>
                                <a href="{{ path('contrato_index') }}" class="btn btn-secondary" title="Limpar">
                                    <i class="bi bi-x-lg"></i>
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-muted"><i class="bi bi-list-ul me-1"></i> {{ contratos|length }} resultado(s) encontrado(s)</span>
        </div>

    {% if contratos|length > 0 %}
    <div class="card">
        <div class="card-body table-responsive p-0">
            <table class="table table-striped table-hover mb-0 table-fixed" id="tabelaContratos">
                <colgroup>
                    <col style="width: 17%">
                    <col style="width: 10%">
                    <col style="width: 10%">
                    <col style="width: 12%">
                    <col style="width: 8%">
                    <col style="width: 18%">
                    <col style="width: 7%">
                    <col style="width: 12%">
                    <col style="width: 6%">
                </colgroup>
                <thead>
                    <tr>
                        <th><i class="bi bi-file-earmark me-1"></i> Título</th>
                        <th><i class="bi bi-calendar-event me-1"></i> Data de Início</th>
                        <th><i class="bi bi-currency-dollar me-1"></i> Valor Total</th>
                        <th><i class="bi bi-person me-1"></i> Responsável</th>
                        <th><i class="bi bi-flag me-1"></i> Status</th>
                        <th><i class="bi bi-people me-1"></i> Clientes Associados</th>
                        <th><i class="bi bi-briefcase me-1"></i> Processos</th>
                        <th class="d-none d-md-table-cell"><i class="bi bi-calendar-plus me-1"></i> Criado em</th>
                        <th class="col-acoes"><i class="bi bi-gear me-1"></i> Ações</th>
                    </tr>
                </thead>
                <tbody>
                    {% for contrato in contratos %}
                        <tr>
                            <td>{{ contrato.titulo }}</td>
                            <td>{% if contrato.dataInicio %}{{ contrato.dataInicio|date('d/m/Y') }}{% else %}-{% endif %}</td>
                            <td>{% if contrato.valorTotal %}R$ {{ contrato.valorTotal|number_format(2, ',', '.') }}{% else %}-{% endif %}</td>
                            <td>{% if contrato.responsavel %}{{ contrato.responsavel.fullName }}{% else %}<span class="text-muted">-</span>{% endif %}</td>
                            <td>
                                {% if contrato.status == 'ATIVO' %}
                                    <span class="badge text-bg-success">{{ contrato.status }}</span>
                                {% else %}
                                    <span class="badge text-bg-danger">{{ contrato.status }}</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if contrato.clientes|length > 0 %}
                                    <ul class="mb-0 list-unstyled">
                                        {% for cliente in contrato.clientes %}
                                            <li>
                                                <a href="{{ path('cliente_show', {id: cliente.id}) }}">
                                                    {% if cliente.cpf is defined %}
                                                        {{ cliente.nomeCompleto }}
                                                    {% else %}
                                                        {{ cliente.razaoSocial }}
                                                    {% endif %}
                                                </a>
                                            </li>
                                        {% endfor %}
                                    </ul>
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if contrato.processos|length > 0 %}
                                    <span class="badge text-bg-info">{{ contrato.processos|length }}</span>
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td class="d-none d-md-table-cell">
                                {% if contrato.criadoAt %}
                                    {% set diasCriado = ((date('now')|date('U') - contrato.criadoAt|date('U')) / 86400)|round(0, 'floor') %}
                                    <span title="{{ contrato.criadoAt|date('d/m/Y H:i') }}">
                                        {% if diasCriado == 0 %}
                                            <i class="bi bi-clock me-1"></i>Hoje
                                        {% elseif diasCriado == 1 %}
                                            <i class="bi bi-calendar me-1"></i>1 dia
                                        {% else %}
                                            <i class="bi bi-calendar me-1"></i>{{ diasCriado }} dias
                                        {% endif %}
                                    </span>
                                {% else %}
                                    -
                                {% endif %}
                            </td>
                            <td class="col-acoes">
                                <div class="btn-acoes">
                                    <a href="{{ path('contrato_show', {id: contrato.id}) }}" class="btn btn-sm btn-info">Ver</a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% else %}
    <div class="alert alert-info mb-0">
        Nenhum contrato encontrado.
    </div>
    {% endif %}
    </div>
</section>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
$(document).ready(function() {
    $('.select2-filter').select2({
        placeholder: 'Selecione...',
        allowClear: true,
        width: '100%'
    });
});
</script>
{% endblock %}
