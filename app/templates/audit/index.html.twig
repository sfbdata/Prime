{% extends 'base.html.twig' %}

{% import _self as auditHelper %}

{% macro formatAuditValue(value) %}
    {% if value is same as(null) %}
        -
    {% elseif value is same as(true) %}
        true
    {% elseif value is same as(false) %}
        false
    {% elseif value is iterable %}
        {{ value|json_encode }}
    {% else %}
        {{ value }}
    {% endif %}
{% endmacro %}

{% macro actionBadgeClass(action) %}
    {% if action == 'create' %}
        text-bg-success
    {% elseif action == 'update' %}
        text-bg-primary
    {% elseif action == 'delete' %}
        text-bg-danger
    {% else %}
        text-bg-secondary
    {% endif %}
{% endmacro %}

{% macro entityRef(item) %}
    {% if item is iterable %}
        {% set label = item.label ?? null %}
        {% set className = item.class is defined ? (item.class|split('\\')|last) : 'Entidade' %}
        {% set id = item.id ?? null %}
        {% if label %}
            {{ label }}
        {% else %}
            {{ className }}
            {% if id %} #{{ id }}{% endif %}
        {% endif %}
    {% else %}
        -
    {% endif %}
{% endmacro %}

{% block title %}Trilha de Auditoria{% endblock %}

{% block body %}
<section class="content-header">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <h1 class="m-0">Trilha de Auditoria</h1>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        {# Filtros #}
        <div class="card card-outline card-primary mb-3">
            <div class="card-header">
                <h3 class="card-title"><i class="bi bi-funnel me-1"></i> Filtros</h3>
                <div class="card-tools">
                    <button type="button" class="btn btn-tool" data-bs-toggle="collapse" data-bs-target="#filtrosAudit">
                        <i class="bi bi-dash-lg"></i>
                    </button>
                </div>
            </div>
            <div class="collapse show" id="filtrosAudit">
                <div class="card-body">
                    <form method="get" action="{{ path('audit_log_index') }}">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label for="entity" class="form-label">Entidade</label>
                                <select id="entity" name="entity" class="form-control select2-filter">
                                    <option value="">Todas</option>
                                    {% for option in entityOptions %}
                                        <option value="{{ option.value }}" {{ filters.entity == option.value ? 'selected' : '' }}>{{ option.label }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label for="user" class="form-label">Usuário</label>
                                <select id="user" name="user" class="form-control select2-filter">
                                    <option value="">Todos</option>
                                    {% for option in userOptions %}
                                        <option value="{{ option.value }}" {{ filters.user == option.value ? 'selected' : '' }}>{{ option.label }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label for="date_from" class="form-label">Data inicial</label>
                                <input type="date" id="date_from" name="date_from" class="form-control" value="{{ filters.date_from }}">
                            </div>
                            <div class="col-md-2">
                                <label for="date_to" class="form-label">Data final</label>
                                <input type="date" id="date_to" name="date_to" class="form-control" value="{{ filters.date_to }}">
                            </div>
                            <div class="col-md-2 d-flex align-items-end gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-search me-1"></i> Filtrar
                                </button>
                                <a href="{{ path('audit_log_index') }}" class="btn btn-secondary">
                                    <i class="bi bi-x-lg me-1"></i> Limpar
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-muted"><i class="bi bi-list-ul me-1"></i> {{ auditLogs|length }} resultado(s) nesta página{% if pagination.total_items is defined %} ({{ pagination.total_items }} total){% endif %}</span>
        </div>

        <div class="card">
            <div class="card-body table-responsive p-0">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th><i class="bi bi-clock me-1"></i> Data/Hora</th>
                            <th><i class="bi bi-person me-1"></i> Usuário</th>
                            <th><i class="bi bi-box me-1"></i> Entidade</th>
                            <th><i class="bi bi-activity me-1"></i> Ação</th>
                            <th><i class="bi bi-card-text me-1"></i> Resumo</th>
                            <th><i class="bi bi-eye me-1"></i> Alterações</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for log in auditLogs %}
                            {% set payload = log.changes ?? {} %}
                            {% set diff = payload.diff ?? payload %}
                            {% set context = payload.context ?? payload._meta ?? {} %}
                            {% set detailId = 'audit-detail-' ~ log.id %}
                            <tr>
                                <td>
                                    <div>{{ log.createdAt|date('d/m/Y H:i:s') }}</div>
                                </td>
                                <td>
                                    {% if log.actorEmail %}
                                        <div>{{ log.actorEmail }}</div>
                                        <small class="text-muted">ID {{ log.actorUserId ?? '-' }}</small>
                                    {% elseif log.actorUserId %}
                                        ID {{ log.actorUserId }}
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                                <td>
                                    {{ log.entityClass|split('\\')|last }}
                                    {% if log.entityId %}
                                        <span class="text-muted">#{{ log.entityId }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <span class="badge {{ auditHelper.actionBadgeClass(log.action) }}">{{ log.action|upper }}</span>
                                </td>
                                <td>
                                    {% if log.action == 'update' and diff.changes is defined and diff.changes is iterable and diff.changes|length > 0 %}
                                        {{ diff.changes|length }} campo(s) alterado(s)
                                    {% elseif log.action == 'create' and diff.after is defined and diff.after is iterable and diff.after|length > 0 %}
                                        {{ diff.after|length }} campo(s) inicializado(s)
                                    {% elseif log.action == 'delete' and diff.before is defined and diff.before is iterable and diff.before|length > 0 %}
                                        {{ diff.before|length }} campo(s) removido(s)
                                    {% else %}
                                        Sem diff detalhado
                                    {% endif %}
                                </td>
                                <td>
                                    <button
                                        class="btn btn-sm btn-info"
                                        type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#{{ detailId }}"
                                        aria-expanded="false"
                                        aria-controls="{{ detailId }}"
                                    >Ver</button>
                                </td>
                            </tr>
                            <tr class="collapse" id="{{ detailId }}">
                                <td colspan="6" class="bg-light">
                                    <div class="p-2">
                                        <div class="small text-muted mb-2">
                                            {% if context.route is defined %}Rota: <strong>{{ context.route }}</strong> | {% endif %}
                                            IP: <strong>{{ log.ipAddress ?? context.ip ?? '-' }}</strong>
                                        </div>

                                        {% if log.action == 'update' and diff.changes is defined and diff.changes is iterable and diff.changes|length > 0 %}
                                            <ul class="mb-0 ps-3">
                                                {% if diff.association_events is defined and diff.association_events is iterable and diff.association_events|length > 0 %}
                                                    {% for event in diff.association_events %}
                                                        <li>
                                                            {% set ownerClass = event.owner.class ?? '' %}
                                                            {% set relatedClass = event.related.class ?? '' %}
                                                            {% set relatedId = event.related.id ?? null %}

                                                            {% if event.operation == 'remove' %}
                                                                {{ auditHelper.entityRef(event.owner ?? null) }} foi removido de {{ event.field ?? 'associação' }} de {{ auditHelper.entityRef(event.related ?? null) }}.
                                                            {% elseif event.operation == 'add' %}
                                                                {{ auditHelper.entityRef(event.owner ?? null) }} foi associado em {{ event.field ?? 'associação' }} com {{ auditHelper.entityRef(event.related ?? null) }}.
                                                            {% else %}
                                                                Associação alterada entre {{ auditHelper.entityRef(event.owner ?? null) }} e {{ auditHelper.entityRef(event.related ?? null) }}.
                                                            {% endif %}
                                                        </li>
                                                    {% endfor %}
                                                {% endif %}

                                                {% for field, fieldDiff in diff.changes %}
                                                    {% if '[+:' not in field and '[-:' not in field %}
                                                        <li>
                                                            <strong>{{ field }}</strong>:
                                                            <span class="text-decoration-line-through text-muted">{{ auditHelper.formatAuditValue(fieldDiff.from ?? null) }}</span>
                                                            <span class="mx-1">→</span>
                                                            <span class="fw-semibold text-primary">{{ auditHelper.formatAuditValue(fieldDiff.to ?? null) }}</span>
                                                        </li>
                                                    {% endif %}
                                                {% endfor %}
                                            </ul>
                                        {% elseif log.action == 'create' and diff.after is defined and diff.after is iterable and diff.after|length > 0 %}
                                            <ul class="mb-0 ps-3">
                                                {% for field, value in diff.after %}
                                                    <li>
                                                        <strong>{{ field }}</strong>:
                                                        <span class="text-decoration-line-through text-muted">-</span>
                                                        <span class="mx-1">→</span>
                                                        <span class="fw-semibold text-success">{{ auditHelper.formatAuditValue(value) }}</span>
                                                    </li>
                                                {% endfor %}
                                            </ul>
                                        {% elseif log.action == 'delete' and diff.before is defined and diff.before is iterable and diff.before|length > 0 %}
                                            <ul class="mb-0 ps-3">
                                                {% for field, value in diff.before %}
                                                    <li>
                                                        <strong>{{ field }}</strong>:
                                                        <span class="text-decoration-line-through text-danger">{{ auditHelper.formatAuditValue(value) }}</span>
                                                        <span class="mx-1">→</span>
                                                        <span class="fw-semibold">-</span>
                                                    </li>
                                                {% endfor %}
                                            </ul>
                                        {% else %}
                                            <span class="text-muted">Sem alterações detalhadas.</span>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="text-center text-muted py-3">Nenhum registro encontrado para os filtros informados.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {% if pagination.total_pages > 1 %}
            {% set pageWindow = 3 %}
            {% set startPage = pagination.current_page - pageWindow %}
            {% set endPage = pagination.current_page + pageWindow %}
            {% if startPage < 1 %}
                {% set startPage = 1 %}
            {% endif %}
            {% if endPage > pagination.total_pages %}
                {% set endPage = pagination.total_pages %}
            {% endif %}

            <nav aria-label="Paginação da trilha de auditoria" class="mt-3">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item {{ pagination.current_page <= 1 ? 'disabled' : '' }}">
                        <a class="page-link" href="{{ path('audit_log_index', filters|merge({'page': pagination.current_page - 1})) }}">Anterior</a>
                    </li>

                    {% for pageNumber in startPage..endPage %}
                        <li class="page-item {{ pageNumber == pagination.current_page ? 'active' : '' }}">
                            <a class="page-link" href="{{ path('audit_log_index', filters|merge({'page': pageNumber})) }}">{{ pageNumber }}</a>
                        </li>
                    {% endfor %}

                    <li class="page-item {{ pagination.current_page >= pagination.total_pages ? 'disabled' : '' }}">
                        <a class="page-link" href="{{ path('audit_log_index', filters|merge({'page': pagination.current_page + 1})) }}">Próxima</a>
                    </li>
                </ul>
            </nav>
        {% endif %}
    </div>
</section>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
$(document).ready(function() {
    $('.select2-filter').select2({
        placeholder: 'Selecione...',
        allowClear: true,
        width: '100%'
    });
});
</script>
{% endblock %}