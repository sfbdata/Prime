{% extends 'base.html.twig' %}

{% block title %}Meu Perfil{% endblock %}

{% block body %}
<section class="content-header">
    <div class="container-fluid">
        <h1 class="m-0"><i class="bi bi-person-circle me-2"></i>Meu Perfil</h1>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8">

                {# ── Card: Dados do usuário ── #}
                <div class="card card-outline card-primary mb-3">
                    <div class="card-header">
                        <h3 class="card-title"><i class="bi bi-person me-2"></i>Dados da Conta</h3>
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Nome</dt>
                            <dd class="col-sm-8">{{ user.fullName }}</dd>

                            <dt class="col-sm-4">E-mail</dt>
                            <dd class="col-sm-8">{{ user.email }}</dd>

                            <dt class="col-sm-4">Perfil</dt>
                            <dd class="col-sm-8">
                                {% if user.tenantRole %}
                                    <span class="badge text-bg-secondary">{{ user.tenantRole.name }}</span>
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </dd>

                            <dt class="col-sm-4">Criado em</dt>
                            <dd class="col-sm-8 text-muted">{{ user.createdAt|date('d/m/Y H:i') }}</dd>
                        </dl>
                    </div>
                    <div class="card-footer">
                        <form action="{{ path('app_logout') }}" method="post">
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-box-arrow-right me-1"></i>Sair da conta
                            </button>
                        </form>
                    </div>
                </div>

                {# ── Card: Permissões específicas por item ── #}
                <div class="card card-outline card-info mb-4">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="bi bi-unlock me-2"></i>Meus Acessos Específicos
                        </h3>
                    </div>
                    <div class="card-body p-0">
                        {% if resourceAccesses is empty %}
                            <div class="p-4 text-center text-muted">
                                <i class="bi bi-info-circle me-1"></i>
                                Você não possui acessos específicos concedidos por item.
                            </div>
                        {% else %}
                            <table class="table table-striped table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th><i class="bi bi-box me-1"></i> Módulo</th>
                                        <th><i class="bi bi-hash me-1"></i> ID</th>
                                        <th><i class="bi bi-shield-check me-1"></i> Ações permitidas</th>
                                        <th><i class="bi bi-calendar me-1"></i> Concedido em</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for ra in resourceAccesses %}
                                        <tr>
                                            <td>
                                                <span class="badge text-bg-secondary text-capitalize">{{ ra.resourceType }}</span>
                                            </td>
                                            <td class="text-muted">#{{ ra.resourceId }}</td>
                                            <td>
                                                {% if ra.canView %}
                                                    <span class="badge text-bg-info me-1">Visualizar</span>
                                                {% endif %}
                                                {% if ra.canEdit %}
                                                    <span class="badge text-bg-warning me-1">Editar</span>
                                                {% endif %}
                                                {% if ra.canDelete %}
                                                    <span class="badge text-bg-danger me-1">Excluir</span>
                                                {% endif %}
                                            </td>
                                            <td class="text-muted small">{{ ra.grantedAt|date('d/m/Y H:i') }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        {% endif %}
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>
{% endblock %}
