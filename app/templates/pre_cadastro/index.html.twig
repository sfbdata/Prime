{% extends 'base.html.twig' %}

{% block title %}Pré-Cadastros{% endblock %}

{% block body %}
<div class="container mt-4">
    <h2 class="mb-3">Lista de Pré-Cadastros</h2>

    <a href="{{ path('pre_cadastro_new') }}" class="btn btn-success mb-3">Novo Pré-Cadastro</a>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Nome</th>
                <th>CPF/CNPJ</th>
                <th>Tipo</th>
                <th>Registrado</th>
                <th>Status do Contrato</th>
                <th>Criado em</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            {% for preCadastro in pre_cadastros %}
                <tr>
                    <td>{{ preCadastro.nomeCliente }}</td>
                    <td>{{ preCadastro.cpf }}</td>
                    <td>
                        {% if preCadastro.tipo == 'PF' %}
                            <span class="badge bg-info">Pessoa Física</span>
                        {% else %}
                            <span class="badge bg-warning">Pessoa Jurídica</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if preCadastro.cliente %}
                            <a href="{{ path('cliente_show', {id: preCadastro.cliente.id}) }}" class="text-decoration-none">
                                <span class="badge bg-success">Registrado</span>
                            </a>
                        {% else %}
                            <span class="badge bg-secondary">Não registrado</span>
                        {% endif %}
                    </td>
                    <td>
                        {% set sc = preCadastro.statusContratoCentralizado %}
                        {% if sc == 'ATIVO' %}
                            <span class="badge text-bg-success">Ativo</span>
                        {% elseif sc == 'PENDENTE' %}
                            <span class="badge text-bg-warning">Pendente</span>
                        {% elseif sc == 'EM_ANDAMENTO' %}
                            <span class="badge text-bg-info">Em Andamento</span>
                        {% elseif sc == 'FINALIZADO' or sc == 'ENCERRADO' %}
                            <span class="badge text-bg-secondary">Encerrado</span>
                        {% elseif sc == 'CANCELADO' %}
                            <span class="badge text-bg-danger">Cancelado</span>
                        {% else %}
                            <span class="badge text-bg-light text-dark">Sem Contrato</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if preCadastro.criadoAt %}
                            {{ preCadastro.criadoAt|date('d/m/Y H:i') }}
                        {% else %}
                            -
                        {% endif %}
                    </td>
                    <td>
                        <div class="acoes-grupo">
                            <a href="{{ path('pre_cadastro_show', {id: preCadastro.id}) }}"
                               class="btn-action btn-action-view"
                               title="Ver detalhes"
                               aria-label="Ver detalhes do pré-cadastro">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a href="{{ path('cliente_from_pre_cadastro', {id: preCadastro.id}) }}"
                               class="btn-action btn-action-edit"
                               title="Cadastrar Cliente"
                               aria-label="Cadastrar cliente a partir do pré-cadastro">
                                <i class="bi bi-person-plus"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="text-center">Nenhum pré-cadastro encontrado.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
