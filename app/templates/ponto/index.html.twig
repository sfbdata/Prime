{% extends 'base.html.twig' %}

{% block title %}Ponto Eletrônico{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-sm-6">
            <h1 class="m-0">Ponto Eletrônico</h1>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card card-primary card-outline">
                <div class="card-header">
                    <h3 class="card-title">Registrar Ponto</h3>
                </div>
                <div class="card-body text-center">
                    <div id="clock" class="h1 mb-4">00:00:00</div>

                    <div id="gps-status" class="alert alert-info small mb-3">
                        <i class="bi bi-geo-alt"></i> Aguardando geolocalização
                    </div>

                    <div class="mb-3 text-start">
                        <label for="tipo-registro" class="form-label fw-semibold">Tipo de registro <span class="text-danger">*</span></label>
                        <select id="tipo-registro" class="form-select" required>
                            <option value="">Selecione...</option>
                            <option value="entrada">Entrada</option>
                            <option value="saida">Saida</option>
                        </select>
                    </div>

                    <button id="btn-bater-ponto" class="btn btn-lg btn-primary w-100" disabled>
                        <i class="bi bi-fingerprint"></i> Bater Ponto
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Últimas Batidas</h3>
                    <div class="card-tools">
                        <a href="{{ path('ponto_exportar_csv') }}" class="btn btn-sm btn-success">
                            <i class="bi bi-file-earmark-spreadsheet"></i> Exportar CSV
                        </a>
                    </div>
                </div>
                <div class="card-body p-0">
                    <table class="table table-striped mb-0">
                        <thead>
                            <tr>
                                <th>Data/Hora</th>
                                <th>Tipo</th>
                                <th>Sede</th>
                                <th>Precisão</th>
                            </tr>
                        </thead>
                        <tbody id="ponto-history">
                            {% if batidas is empty %}
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-3">Nenhum registro encontrado.</td>
                                </tr>
                            {% else %}
                                {% for batida in batidas %}
                                    <tr>
                                        <td>{{ batida.dataHora|date('d/m/Y H:i:s') }}</td>
                                        <td>
                                            {% set tipoLabels = {'entrada': 'Entrada', 'saida': 'Saída', 'entrada_intervalo': 'Início Intervalo', 'saida_intervalo': 'Fim Intervalo'} %}
                                            <span class="badge bg-{{ batida.tipo starts with 'entrada' ? 'success' : 'warning' }}">
                                                {{ tipoLabels[batida.tipo] ?? batida.tipo }}
                                            </span>
                                        </td>
                                        <td>{{ batida.sede ? batida.sede.nome : 'N/A' }}</td>
                                        <td>{{ batida.precisaoGps }}m</td>
                                    </tr>
                                {% endfor %}
                            {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Relógio em tempo real
    function updateClock() {
        const now = new Date();
        document.getElementById('clock').textContent = now.toLocaleTimeString('pt-BR');
    }
    setInterval(updateClock, 1000);
    updateClock();

    const btnPonto = document.getElementById('btn-bater-ponto');
    const gpsStatus = document.getElementById('gps-status');
    const tipoRegistro = document.getElementById('tipo-registro');
    let currentLocation = null;

    function updateButtonState() {
        btnPonto.disabled = !currentLocation || !tipoRegistro.value;
    }

    tipoRegistro.addEventListener('change', updateButtonState);

    // Geolocalização obrigatória
    if ("geolocation" in navigator) {
        navigator.geolocation.getCurrentPosition(
            (position) => {
                const accuracy = position.coords.accuracy;
                currentLocation = {
                    latitude: position.coords.latitude,
                    longitude: position.coords.longitude,
                    precisaoGps: accuracy,
                };

                gpsStatus.innerHTML = `<i class="bi bi-geo-alt-fill"></i> GPS: ${accuracy.toFixed(1)}m de precisão`;
                if (accuracy <= 50) {
                    gpsStatus.className = 'alert alert-success small mb-3';
                } else {
                    gpsStatus.className = 'alert alert-warning small mb-3';
                }

                updateButtonState();
            },
            (error) => {
                gpsStatus.innerHTML = `<i class="bi bi-exclamation-triangle"></i> Permita o acesso à localização para registrar o ponto.`;
                gpsStatus.className = 'alert alert-danger small mb-3';
                btnPonto.disabled = true;
                console.log('GPS não disponível:', error.message);
            },
            { enableHighAccuracy: true, timeout: 5000 }
        );
    } else {
        gpsStatus.innerHTML = `<i class="bi bi-exclamation-triangle"></i> Seu navegador não suporta geolocalização.`;
        gpsStatus.className = 'alert alert-danger small mb-3';
    }

    // Botão de Bater Ponto
    btnPonto.addEventListener('click', async function() {
        if (!tipoRegistro.value) {
            alert('Selecione o tipo de registro (Entrada ou Saida).');
            return;
        }

        if (!currentLocation) {
            alert('A localização é obrigatória para registrar o ponto.');
            return;
        }

        btnPonto.disabled = true;
        btnPonto.innerHTML = '<i class="bi bi-hourglass-split"></i> Registrando...';

        let latitude = currentLocation.latitude;
        let longitude = currentLocation.longitude;
        let precisaoGps = currentLocation.precisaoGps;

        if ("geolocation" in navigator) {
            try {
                const position = await new Promise((resolve, reject) => {
                    navigator.geolocation.getCurrentPosition(resolve, reject, { enableHighAccuracy: true, timeout: 5000 });
                });

                latitude = position.coords.latitude;
                longitude = position.coords.longitude;
                precisaoGps = position.coords.accuracy;
                currentLocation = { latitude, longitude, precisaoGps };
            } catch (err) {
                console.log('Não foi possível atualizar GPS:', err);
            }
        }

        try {
            const response = await fetch('{{ path('ponto_batida') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({
                    latitude: latitude,
                    longitude: longitude,
                    precisaoGps: precisaoGps,
                    tipo: tipoRegistro.value
                })
            });

            const data = await response.json();

            if (response.ok && data.success) {
                gpsStatus.innerHTML = `<i class="bi bi-check-circle"></i> ${data.message}`;
                gpsStatus.className = 'alert alert-success small mb-3';
                setTimeout(() => window.location.reload(), 1500);
            } else {
                alert(data.message || 'Erro ao registrar ponto.');
                btnPonto.disabled = false;
                btnPonto.innerHTML = '<i class="bi bi-fingerprint"></i> Bater Ponto';
            }
        } catch (error) {
            alert('Erro de conexão. Tente novamente.');
            console.error('Erro:', error);
            btnPonto.disabled = false;
            btnPonto.innerHTML = '<i class="bi bi-fingerprint"></i> Bater Ponto';
        }
    });
</script>
{% endblock %}
