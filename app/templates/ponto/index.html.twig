{% extends 'base.html.twig' %}

{% block title %}Ponto Eletrônico{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-sm-6">
            <h1 class="m-0">Ponto Eletrônico</h1>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card card-primary card-outline">
                <div class="card-header">
                    <h3 class="card-title">Registrar Ponto</h3>
                </div>
                <div class="card-body text-center">
                    {% if saldoMes is not null %}
                        {% set absAcum = saldoMes < 0 ? -saldoMes : saldoMes %}
                        <div class="mb-3">
                            <small class="text-muted d-block">Saldo</small>
                            <span class="h4 fw-bold {{ saldoMes >= 0 ? 'text-success' : 'text-danger' }}">
                                {{ saldoMes < 0 ? '-' : '+' }}{{ (absAcum // 60) }}h{{ '%02d'|format(absAcum % 60) }}m
                            </span>
                        </div>
                    {% endif %}
                    <div id="clock" class="h1 mb-4" title="Tempo trabalhado hoje">00:00:00</div>
                    <div id="clock-label" class="text-muted small mb-2"></div>

                    <div id="gps-status" class="alert alert-info small mb-3">
                        <i class="bi bi-geo-alt"></i> Aguardando geolocalização
                    </div>

                    <div class="mb-3 text-start">
                        <label for="tipo-registro" class="form-label fw-semibold">Tipo de registro <span class="text-danger">*</span></label>
                        <select id="tipo-registro" class="form-select" required>
                            <option value="">Selecione...</option>
                            <option value="entrada">Entrada</option>
                            <option value="repouso">Repouso</option>
                            <option value="retorno">Retorno</option>
                            <option value="saida">Saída</option>
                        </select>
                    </div>

                    <button id="btn-bater-ponto" class="btn btn-lg btn-primary w-100" disabled>
                        <i class="bi bi-fingerprint"></i> Bater Ponto
                    </button>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            {% include 'ponto/_folha_table.html.twig' with {
                titulo: 'Folha de Ponto - ' ~ ('%02d'|format(mesAtual)) ~ '/' ~ anoAtual,
                folhaRows: folhaRows,
                competenciasPonto: competenciasPonto,
                competenciaSelecionada: competenciaSelecionada,
                competenciaFormAction: path('ponto_index'),
                competenciaFieldId: 'competencia-ponto-index',
                exportarFolhaHabilitado: true,
                exportarFolhaRota: 'ponto_exportar_pdf',
                mostrarBancoHoras: true,
                editarBatidasHabilitado: false
            } only %}
        </div>
    </div>
</div>

<script>
    const GPS_PRECISAO_ACEITAVEL_METROS = 90;

    // Contador de tempo trabalhado no dia
    (function() {
        const pontoHoje = {{ pontoHoje|default({})|json_encode|raw }};

        const clockEl = document.getElementById('clock');
        const labelEl = document.getElementById('clock-label');

        function parseHMS(hms) {
            if (!hms) return null;
            const today = new Date().toISOString().slice(0, 10);
            return new Date(today + 'T' + hms);
        }

        const tEntrada = parseHMS(pontoHoje.entrada);
        const tRepouso = parseHMS(pontoHoje.repouso);
        const tRetorno = parseHMS(pontoHoje.retorno);
        const tSaida   = parseHMS(pontoHoje.saida);

        function calcSegundosTrabalhados(agora) {
            if (!tEntrada) return 0;

            let total = 0;
            const fim1 = tRepouso || tSaida || agora;
            total += Math.max(0, fim1 - tEntrada);

            if (tRetorno) {
                const fim2 = tSaida || agora;
                total += Math.max(0, fim2 - tRetorno);
            }

            return Math.floor(total / 1000);
        }

        function formatarTempo(segundos) {
            const h = Math.floor(segundos / 3600);
            const m = Math.floor((segundos % 3600) / 60);
            const s = segundos % 60;
            return String(h).padStart(2, '0') + ':' + String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
        }

        function updateClock() {
            const agora = new Date();
            let label = '';

            if (!tEntrada) {
                clockEl.textContent = '00:00:00';
                label = 'Aguardando entrada';
            } else if (tSaida) {
                const segundos = calcSegundosTrabalhados(agora);
                clockEl.textContent = formatarTempo(segundos);
                label = 'Jornada encerrada';
            } else if (tRepouso && !tRetorno) {
                const segundos = calcSegundosTrabalhados(agora);
                clockEl.textContent = formatarTempo(segundos);
                label = 'Em repouso';
            } else {
                const segundos = calcSegundosTrabalhados(agora);
                clockEl.textContent = formatarTempo(segundos);
                label = 'Tempo trabalhado';
            }

            labelEl.textContent = label;
        }

        setInterval(updateClock, 1000);
        updateClock();
    })();

    const btnPonto = document.getElementById('btn-bater-ponto');
    const gpsStatus = document.getElementById('gps-status');
    const tipoRegistro = document.getElementById('tipo-registro');
    let currentLocation = null;

    function updateButtonState() {
        btnPonto.disabled = !currentLocation || !tipoRegistro.value;
    }

    tipoRegistro.addEventListener('change', updateButtonState);

    // Geolocalização obrigatória
    function aplicarPosicao(position) {
        const accuracy = position.coords.accuracy;
        currentLocation = {
            latitude: position.coords.latitude,
            longitude: position.coords.longitude,
            precisaoGps: accuracy,
        };

        if (accuracy <= GPS_PRECISAO_ACEITAVEL_METROS) {
            gpsStatus.innerHTML = `<i class="bi bi-geo-alt-fill"></i> GPS: ${accuracy.toFixed(1)}m de precisão`;
            gpsStatus.className = 'alert alert-success small mb-3';
        } else {
            gpsStatus.innerHTML = `<i class="bi bi-exclamation-triangle"></i> GPS impreciso (${accuracy.toFixed(1)}m). O sistema ainda validará se você está dentro do raio de alguma sede.`;
            gpsStatus.className = 'alert alert-warning small mb-3';
        }

        updateButtonState();
    }

    function erroGps(error) {
        gpsStatus.innerHTML = `<i class="bi bi-exclamation-triangle"></i> Permita o acesso à localização para registrar o ponto.`;
        gpsStatus.className = 'alert alert-danger small mb-3';
        btnPonto.disabled = true;
        console.log('GPS não disponível:', error.message);
    }

    if ("geolocation" in navigator) {
        navigator.geolocation.getCurrentPosition(
            aplicarPosicao,
            (error) => {
                // Fallback sem alta precisão caso o primeiro tente atingir timeout
                navigator.geolocation.getCurrentPosition(aplicarPosicao, erroGps, { timeout: 10000 });
            },
            { enableHighAccuracy: true, timeout: 10000 }
        );
    } else {
        gpsStatus.innerHTML = `<i class="bi bi-exclamation-triangle"></i> Seu navegador não suporta geolocalização.`;
        gpsStatus.className = 'alert alert-danger small mb-3';
    }

    // Botão de Bater Ponto
    btnPonto.addEventListener('click', async function() {
        if (!tipoRegistro.value) {
            alert('Selecione o tipo de registro (Entrada, Repouso, Retorno ou Saída).');
            return;
        }

        if (!currentLocation) {
            alert('A localização é obrigatória para registrar o ponto.');
            return;
        }

        btnPonto.disabled = true;
        btnPonto.innerHTML = '<i class="bi bi-hourglass-split"></i> Registrando...';

        let latitude = currentLocation.latitude;
        let longitude = currentLocation.longitude;
        let precisaoGps = currentLocation.precisaoGps;

        if ("geolocation" in navigator) {
            try {
                const position = await new Promise((resolve, reject) => {
                    navigator.geolocation.getCurrentPosition(resolve, reject, { enableHighAccuracy: true, timeout: 5000 });
                });

                latitude = position.coords.latitude;
                longitude = position.coords.longitude;
                precisaoGps = position.coords.accuracy;
                currentLocation = { latitude, longitude, precisaoGps };
            } catch (err) {
                console.log('Não foi possível atualizar GPS:', err);
            }
        }

        try {
            const response = await fetch('{{ path('ponto_batida') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({
                    latitude: latitude,
                    longitude: longitude,
                    precisaoGps: precisaoGps,
                    tipo: tipoRegistro.value
                })
            });

            const data = await response.json();

            if (response.ok && data.success) {
                gpsStatus.innerHTML = `<i class="bi bi-check-circle"></i> ${data.message}`;
                gpsStatus.className = 'alert alert-success small mb-3';
                setTimeout(() => window.location.reload(), 1500);
            } else {
                alert(data.message || 'Erro ao registrar ponto.');
                btnPonto.disabled = false;
                btnPonto.innerHTML = '<i class="bi bi-fingerprint"></i> Bater Ponto';
            }
        } catch (error) {
            alert('Erro de conexão. Tente novamente.');
            console.error('Erro:', error);
            btnPonto.disabled = false;
            btnPonto.innerHTML = '<i class="bi bi-fingerprint"></i> Bater Ponto';
        }
    });
</script>
{% endblock %}
