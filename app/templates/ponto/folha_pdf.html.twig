<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Folha de Ponto - {{ '%02d'|format(mes) }}/{{ ano }}</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            font-size: 11px;
            color: #333;
            margin: 20px;
        }
        h2 {
            font-size: 14px;
            text-align: center;
            margin-bottom: 4px;
        }
        .subtitulo {
            text-align: center;
            font-size: 11px;
            color: #555;
            margin-bottom: 16px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        thead tr th {
            background-color: #2c5f8a;
            color: #fff;
            padding: 5px 8px;
            text-align: left;
            font-size: 10px;
            border: 1px solid #1e4569;
        }
        tbody tr td {
            padding: 4px 8px;
            border: 1px solid #ccc;
        }
        tbody tr.fim-semana td {
            background-color: #eaeaea;
        }
        tbody tr:not(.fim-semana):nth-child(even) td {
            background-color: #f5f5f5;
        }
    </style>
</head>
<body>
    <h2>Folha de Ponto — {{ nomeUsuario }}</h2>
    <p class="subtitulo">{{ '%02d'|format(mes) }}/{{ ano }}</p>

    <table>
        <thead>
            <tr>
                <th>Dia do Mês</th>
                <th>Dia da Semana</th>
                <th>Entrada</th>
                <th>Repouso</th>
                <th>Retorno</th>
                <th>Saída</th>
            </tr>
        </thead>
        <tbody>
            {% for linha in folhaRows %}
                <tr class="{{ linha.fimSemana ? 'fim-semana' : '' }}">
                    <td>{{ linha.diaMes }}</td>
                    <td>{{ linha.diaSemana }}</td>
                    <td>{{ linha.entrada }}</td>
                    <td>{{ linha.repouso }}</td>
                    <td>{{ linha.retorno }}</td>
                    <td>{{ linha.saida }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</body>
</html>
