{% extends 'base.html.twig' %}

{% block title %}Cliente - {{ cliente.cpf is defined ? cliente.nomeCompleto : cliente.razaoSocial }}{% endblock %}

{% block body %}
{# Content Header #}
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <i class="bi bi-person me-2"></i>{{ cliente.cpf is defined ? cliente.nomeCompleto : cliente.razaoSocial }}
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-end">
                    <li class="breadcrumb-item"><a href="{{ path('homepage') }}">Home</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('cliente_index') }}">Clientes</a></li>
                    <li class="breadcrumb-item active">Detalhes</li>
                </ol>
            </div>
        </div>
    </div>
</div>

{# Main Content #}
<section class="content">
    <div class="container-fluid">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h3 class="card-title">{{ cliente.cpf is defined ? 'Pessoa Física' : 'Pessoa Jurídica' }}</h3>
                <div class="card-tools">
                    <span class="badge text-bg-primary">
                        {{ cliente.cpf is defined ? cliente.cpf : cliente.cnpj }}
                    </span>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    {# Left Column - Tabs #}
                    <div class="col-12 col-md-12 col-lg-8 order-2 order-md-1">
                        {# Info Boxes #}
                        <div class="row">
                            <div class="col-12 col-sm-4">
                                <div class="info-box bg-light">
                                    <div class="info-box-content">
                                        <span class="info-box-text text-center text-muted">Tipo</span>
                                        <span class="info-box-number text-center text-muted mb-0">{{ cliente.cpf is defined ? 'PF' : 'PJ' }}</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# Tabs #}
                        <ul class="nav nav-tabs" id="clienteTabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="dados-tab" data-bs-toggle="tab" data-bs-target="#dados" type="button" role="tab" aria-controls="dados" aria-selected="true">
                                    <i class="bi bi-person-vcard me-1"></i> Dados do Cliente
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="info-tab" data-bs-toggle="tab" data-bs-target="#info" type="button" role="tab" aria-controls="info" aria-selected="false">
                                    <i class="bi bi-info-circle me-1"></i> Informações
                                </button>
                            </li>
                        </ul>

                        <div class="tab-content mt-3" id="clienteTabsContent">
                            {# Tab: Dados do Cliente #}
                            <div class="tab-pane fade show active" id="dados" role="tabpanel" aria-labelledby="dados-tab">
                                {# NUP - comum a PF e PJ #}
                                <div class="row mb-4">
                                    <div class="col-md-6">
                                        <div class="text-muted">
                                            <p class="text-sm mb-2">NUP <i class="bi bi-info-circle text-secondary" data-bs-toggle="tooltip" data-bs-placement="top" title="NÚMERO ÚNICO DE PASTA"></i>
                                                <b class="d-block">{{ cliente.nup ?: '-' }}{% if cliente.nup %} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.nup }}" title="Copiar"></i>{% endif %}</b>
                                            </p>
                                        </div>
                                    </div>
                                </div>

                                {% if cliente.cpf is defined %}
                                    {# Pessoa Física #}
                                    <h5 class="mb-3"><i class="bi bi-person-badge me-1"></i> Dados Pessoais</h5>
                                    <div class="row mb-4">
                                        <div class="col-md-6">
                                            <div class="text-muted">
                                                <p class="text-sm mb-2">Nome Completo
                                                    <b class="d-block">{{ cliente.nomeCompleto }} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.nomeCompleto }}" title="Copiar"></i></b>
                                                </p>
                                                <p class="text-sm mb-2">CPF
                                                    <b class="d-block">{{ cliente.cpf }} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.cpf }}" title="Copiar"></i></b>
                                                </p>
                                                <p class="text-sm mb-2">Data de Nascimento
                                                    <b class="d-block">{% if cliente.dataNascimento %}{{ cliente.dataNascimento|date('d/m/Y') }} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.dataNascimento|date('d/m/Y') }}" title="Copiar"></i>{% else %}-{% endif %}</b>
                                                </p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="text-muted">
                                                <p class="text-sm mb-2">Estado Civil
                                                    <b class="d-block">{{ cliente.estadoCivil ?: '-' }}{% if cliente.estadoCivil %} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.estadoCivil }}" title="Copiar"></i>{% endif %}</b>
                                                </p>
                                                <p class="text-sm mb-2">Profissão
                                                    <b class="d-block">{{ cliente.profissao ?: '-' }}{% if cliente.profissao %} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.profissao }}" title="Copiar"></i>{% endif %}</b>
                                                </p>
                                            </div>
                                        </div>
                                    </div>

                                    <h5 class="mb-3"><i class="bi bi-card-text me-1"></i> Documento RG</h5>
                                    <div class="row mb-4">
                                        <div class="col-md-4">
                                            <div class="text-muted">
                                                <p class="text-sm mb-2">RG
                                                    <b class="d-block">{{ cliente.rg ?: '-' }}{% if cliente.rg %} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.rg }}" title="Copiar"></i>{% endif %}</b>
                                                </p>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="text-muted">
                                                <p class="text-sm mb-2">Órgão Expedidor
                                                    <b class="d-block">{{ cliente.rgOrgaoExpedidor ?: '-' }}{% if cliente.rgOrgaoExpedidor %} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.rgOrgaoExpedidor }}" title="Copiar"></i>{% endif %}</b>
                                                </p>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="text-muted">
                                                <p class="text-sm mb-2">Data de Emissão
                                                    <b class="d-block">{% if cliente.rgDataEmissao %}{{ cliente.rgDataEmissao|date('d/m/Y') }} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.rgDataEmissao|date('d/m/Y') }}" title="Copiar"></i>{% else %}-{% endif %}</b>
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                {% else %}
                                    {# Pessoa Jurídica #}
                                    <h5 class="mb-3"><i class="bi bi-building me-1"></i> Dados da Empresa</h5>
                                    <div class="row mb-4">
                                        <div class="col-md-6">
                                            <div class="text-muted">
                                                <p class="text-sm mb-2">Razão Social
                                                    <b class="d-block">{{ cliente.razaoSocial }} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.razaoSocial }}" title="Copiar"></i></b>
                                                </p>
                                                <p class="text-sm mb-2">Nome Fantasia
                                                    <b class="d-block">{{ cliente.nomeFantasia ?: '-' }}{% if cliente.nomeFantasia %} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.nomeFantasia }}" title="Copiar"></i>{% endif %}</b>
                                                </p>
                                                <p class="text-sm mb-2">CNPJ
                                                    <b class="d-block">{{ cliente.cnpj }} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.cnpj }}" title="Copiar"></i></b>
                                                </p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="text-muted">
                                                <p class="text-sm mb-2">Inscrição Estadual
                                                    <b class="d-block">{{ cliente.inscricaoEstadual ?: '-' }}{% if cliente.inscricaoEstadual %} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.inscricaoEstadual }}" title="Copiar"></i>{% endif %}</b>
                                                </p>
                                                <p class="text-sm mb-2">Inscrição Municipal
                                                    <b class="d-block">{{ cliente.inscricaoMunicipal ?: '-' }}{% if cliente.inscricaoMunicipal %} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.inscricaoMunicipal }}" title="Copiar"></i>{% endif %}</b>
                                                </p>
                                            </div>
                                        </div>
                                    </div>

                                    <h5 class="mb-3"><i class="bi bi-person-workspace me-1"></i> Representante Legal</h5>
                                    <div class="row mb-4">
                                        <div class="col-md-6">
                                            <div class="text-muted">
                                                <p class="text-sm mb-2">Nome
                                                    <b class="d-block">{{ cliente.representanteLegal ?: '-' }}{% if cliente.representanteLegal %} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.representanteLegal }}" title="Copiar"></i>{% endif %}</b>
                                                </p>
                                                <p class="text-sm mb-2">CPF
                                                    <b class="d-block">{{ cliente.representanteCpf ?: '-' }}{% if cliente.representanteCpf %} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.representanteCpf }}" title="Copiar"></i>{% endif %}</b>
                                                </p>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="text-muted">
                                                <p class="text-sm mb-2">RG
                                                    <b class="d-block">{{ cliente.representanteRg ?: '-' }}{% if cliente.representanteRg %} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.representanteRg }}" title="Copiar"></i>{% endif %}</b>
                                                </p>
                                                <p class="text-sm mb-2">Cargo
                                                    <b class="d-block">{{ cliente.representanteCargo ?: '-' }}{% if cliente.representanteCargo %} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.representanteCargo }}" title="Copiar"></i>{% endif %}</b>
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                {% endif %}

                                <h5 class="mb-3"><i class="bi bi-telephone me-1"></i> Contato</h5>
                                <div class="row mb-4">
                                    <div class="col-md-6">
                                        <div class="text-muted">
                                            <p class="text-sm mb-2">E-mail
                                                <b class="d-block">{{ cliente.email }} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.email }}" title="Copiar"></i></b>
                                            </p>
                                            <p class="text-sm mb-2">Celular
                                                <b class="d-block">{{ cliente.telefoneCelular ?: '-' }}{% if cliente.telefoneCelular %} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.telefoneCelular }}" title="Copiar"></i>{% endif %}</b>
                                            </p>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="text-muted">
                                            <p class="text-sm mb-2">Telefone Fixo
                                                <b class="d-block">{{ cliente.telefoneFixo ?: '-' }}{% if cliente.telefoneFixo %} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.telefoneFixo }}" title="Copiar"></i>{% endif %}</b>
                                            </p>
                                        </div>
                                    </div>
                                </div>

                                <h5 class="mb-3"><i class="bi bi-geo-alt me-1"></i> Endereço</h5>
                                <div class="row">
                                    <div class="col-md-12">
                                        <div class="text-muted">
                                            <p class="text-sm mb-2">CEP
                                                <b class="d-block">{{ cliente.cep ?: '-' }}{% if cliente.cep %} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.cep }}" title="Copiar"></i>{% endif %}</b>
                                            </p>
                                            <p class="text-sm mb-2">Endereço
                                                <b class="d-block">{{ cliente.endereco ?: '-' }}{% if cliente.endereco %} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.endereco }}" title="Copiar"></i>{% endif %}</b>
                                            </p>
                                            {% if cliente.complemento %}
                                            <p class="text-sm mb-2">Complemento
                                                <b class="d-block">{{ cliente.complemento }} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.complemento }}" title="Copiar"></i></b>
                                            </p>
                                            {% endif %}
                                            <p class="text-sm mb-0">Cidade/Estado
                                                <b class="d-block">{{ cliente.cidade ?: '-' }} - {{ cliente.estado ?: '-' }}{% if cliente.cidade %} <i class="bi bi-copy text-primary copy-btn" role="button" data-copy="{{ cliente.cidade }} - {{ cliente.estado }}" title="Copiar"></i>{% endif %}</b>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            {# Tab: Informações #}
                            <div class="tab-pane fade" id="info" role="tabpanel" aria-labelledby="info-tab">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="text-muted">
                                            <p class="text-sm mb-2"><i class="bi bi-calendar-plus me-2"></i> Criado em
                                                <b class="d-block">{% if cliente.criadoAt %}{{ cliente.criadoAt|date('d/m/Y H:i') }}{% else %}-{% endif %}</b>
                                            </p>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="text-muted">
                                            <p class="text-sm mb-2"><i class="bi bi-calendar-check me-2"></i> Modificado em
                                                <b class="d-block">{% if cliente.modificadoEm %}{{ cliente.modificadoEm|date('d/m/Y H:i') }}{% else %}-{% endif %}</b>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    {# Right Column - Sidebar #}
                    <div class="col-12 col-md-12 col-lg-4 order-1 order-md-2">
                        <div class="card card-primary card-outline">
                            <div class="card-header">
                                <h3 class="card-title"><i class="bi bi-link-45deg me-1"></i> Vínculos</h3>
                            </div>
                            <div class="card-body">
                                {# Processos #}
                                <h6 class="text-muted mb-3"><i class="bi bi-briefcase me-1"></i> Processos</h6>
                                <p class="text-muted small mb-3"><i class="bi bi-info-circle me-1"></i> Nenhum processo cadastrado.</p>

                                {# Pastas #}
                                <h6 class="text-muted mb-3"><i class="bi bi-folder me-1"></i> Pastas</h6>
                                {% if pastas is empty %}
                                    <p class="text-muted small mb-0"><i class="bi bi-info-circle me-1"></i> Nenhuma pasta vinculada.</p>
                                {% else %}
                                    {% for pasta in pastas %}
                                        <div class="vinculo-link mb-1">
                                            <a href="{{ path('pasta_show', {id: pasta.id}) }}" class="text-decoration-none">
                                                <i class="bi bi-folder2-open me-1 text-warning"></i>
                                                <span class="fw-semibold">{{ pasta.nup }}</span>
                                            </a>
                                            <span class="badge ms-1 {% if pasta.status == 'ativo' %}text-bg-success{% else %}text-bg-secondary{% endif %} small">
                                                {{ pasta.status|capitalize }}
                                            </span>
                                        </div>
                                    {% endfor %}
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer">
                <div class="d-flex justify-content-between">
                    <a href="{{ path('cliente_index') }}" class="btn btn-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Voltar aos Clientes
                    </a>
                    <div class="d-flex gap-2">
                        <a href="{{ path('cliente_edit', {id: cliente.id}) }}"
                           class="btn btn-outline-primary btn-sm"
                           title="Editar cliente"
                           aria-label="Editar cliente">
                            <i class="bi bi-pencil me-1"></i> Editar
                        </a>
                        <form method="post" action="{{ path('cliente_delete', {id: cliente.id}) }}" onsubmit="return confirm('Tem certeza que deseja excluir este cliente?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ cliente.id) }}">
                            <button type="submit"
                                    class="btn btn-outline-danger btn-sm"
                                    title="Excluir cliente"
                                    aria-label="Excluir cliente">
                                <i class="bi bi-trash me-1"></i> Excluir Cliente
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
.copy-btn {
    cursor: pointer;
    opacity: 0.6;
    font-size: 0.85em;
    transition: opacity 0.2s, color 0.2s;
}
.copy-btn:hover {
    opacity: 1;
}
.copy-btn.copied {
    color: #198754 !important;
}
.vinculo-link {
    transition: background-color 0.2s;
    border-radius: 4px;
    padding: 8px;
    margin-left: -8px;
    margin-right: -8px;
}
.vinculo-link:hover {
    background-color: rgba(0,0,0,0.03);
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Inicializar tooltips do Bootstrap
    var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
    tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl);
    });

    document.querySelectorAll('.copy-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            const text = this.getAttribute('data-copy');
            navigator.clipboard.writeText(text).then(() => {
                this.classList.remove('bi-copy');
                this.classList.add('bi-check-lg', 'copied');
                setTimeout(() => {
                    this.classList.remove('bi-check-lg', 'copied');
                    this.classList.add('bi-copy');
                }, 1500);
            });
        });
    });
});
</script>
{% endblock %}
