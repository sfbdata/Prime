{% extends 'base.html.twig' %}

{% block title %}Novo Contrato - {{ cliente.cpf is defined ? cliente.nomeCompleto : cliente.razaoSocial }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
<style>
    .select2-container--bootstrap-5 .select2-selection {
        min-height: 38px;
    }
</style>
{% endblock %}

{% block body %}
<section class="content-header">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <h1 class="m-0"><i class="bi bi-file-earmark-plus me-2"></i> Novo Contrato</h1>
        <a href="{{ path('cliente_show', {id: cliente.id}) }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i> Voltar ao Cliente
        </a>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h3 class="card-title">
                    Criar contrato para: {{ cliente.cpf is defined ? cliente.nomeCompleto : cliente.razaoSocial }}
                </h3>
            </div>
            <div class="card-body">
                {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
                
                <div class="row">
                    <div class="col-md-12 mb-3">
                        {{ form_label(form.titulo, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.titulo, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.titulo) }}
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12 mb-3">
                        {{ form_label(form.descricao, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.descricao, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.descricao) }}
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.dataInicio, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.dataInicio, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.dataInicio) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.valorTotal, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.valorTotal, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.valorTotal) }}
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.responsavel, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.responsavel) }}
                        {{ form_errors(form.responsavel) }}
                        <small class="text-muted">Funcionário responsável pelo contrato</small>
                    </div>
                </div>

                <div class="d-flex justify-content-between">
                    <a href="{{ path('cliente_show', {id: cliente.id}) }}" class="btn btn-secondary">
                        <i class="bi bi-x-lg me-1"></i> Cancelar
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i> Criar Contrato
                    </button>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</section>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/i18n/pt-BR.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    $('.select2-responsavel').select2({
        theme: 'bootstrap-5',
        language: 'pt-BR',
        allowClear: true,
        placeholder: 'Pesquisar funcionário...',
        width: '100%'
    });
});
</script>
{% endblock %}
