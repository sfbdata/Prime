{% extends 'base.html.twig' %}

{% block title %}Editar Permissões{% endblock %}

{% block body %}
<section class="content-header">
    <div class="container-fluid">
        <h1 class="m-0"><i class="bi bi-shield-lock me-2"></i>Editar Permissões</h1>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8">

                {# Perfil e senha #}
                <div class="card card-outline card-primary mb-3">
                    <div class="card-header">
                        <h3 class="card-title"><i class="bi bi-person me-2"></i>{{ user.fullName }}</h3>
                    </div>
                    <div class="card-body">
                        {{ form_start(form) }}
                            <div class="mb-4">
                                {{ form_label(form.tenantRole, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                {{ form_widget(form.tenantRole) }}
                                {{ form_errors(form.tenantRole) }}
                            </div>

                            <hr class="my-4">

                            <h6 class="mb-3"><i class="bi bi-key me-1"></i>Alterar Senha (opcional)</h6>
                            <p class="text-muted small">Preencha os campos abaixo apenas se desejar alterar a senha.</p>

                            <div class="mb-3">
                                {{ form_label(form.newPassword.first, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.newPassword.first, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.newPassword.first) }}
                            </div>

                            <div class="mb-3">
                                {{ form_label(form.newPassword.second, null, {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(form.newPassword.second, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(form.newPassword.second) }}
                            </div>

                            {{ form_errors(form.newPassword) }}
                    </div>
                    <div class="card-footer">
                        <div class="d-flex gap-2 justify-content-between">
                            <a href="{{ path('app_tenant_users', {id: user.tenant.id}) }}" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Voltar
                            </a>
                            <button class="btn btn-primary">
                                <i class="bi bi-check-lg me-1"></i>Salvar
                            </button>
                        </div>
                    </div>
                    {{ form_end(form) }}
                </div>

                {# Acessos específicos por item #}
                <div class="card card-outline card-secondary mb-3">
                    <div class="card-header">
                        <h3 class="card-title"><i class="bi bi-unlock me-2"></i>Acessos específicos por item</h3>
                    </div>
                    <div class="card-body p-0">
                        {% if userAccesses is empty %}
                            <p class="text-muted small p-3 mb-0">Nenhum acesso específico concedido a este usuário.</p>
                        {% else %}
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Tipo</th>
                                        <th>Item</th>
                                        <th>Permissões</th>
                                        <th>Concedido por</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for ra in userAccesses %}
                                        {% set label = resourceLabels[ra.resourceType][ra.resourceId] ?? (ra.resourceType ~ ' #' ~ ra.resourceId) %}
                                        <tr>
                                            <td class="align-middle">
                                                <span class="badge text-bg-light border text-capitalize">{{ ra.resourceType }}</span>
                                            </td>
                                            <td class="align-middle">{{ label }}</td>
                                            <td class="align-middle">
                                                {% if ra.canView %}
                                                    <span class="badge text-bg-info me-1">Ver</span>
                                                {% endif %}
                                                {% if ra.canEdit %}
                                                    <span class="badge text-bg-warning text-dark me-1">Editar</span>
                                                {% endif %}
                                                {% if ra.canDelete %}
                                                    <span class="badge text-bg-danger me-1">Excluir</span>
                                                {% endif %}
                                            </td>
                                            <td class="align-middle small text-muted">
                                                {% if ra.grantedBy %}
                                                    {{ ra.grantedBy.fullName }}
                                                {% else %}
                                                    —
                                                {% endif %}
                                            </td>
                                            <td class="align-middle text-end">
                                                <form method="POST"
                                                      action="{{ path('app_tenant_user_resource_access_remove', {tenantId: tenantId, userId: user.id, raId: ra.id}) }}"
                                                      onsubmit="return confirm('Remover este acesso específico?')">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('remove_resource_access_' ~ ra.id) }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Remover acesso">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        {% endif %}
                    </div>
                </div>

                <div class="card card-outline card-info mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h3 class="card-title mb-0"><i class="bi bi-clock-history me-2"></i>Batidas de ponto</h3>
                        <form method="get" action="{{ path('app_tenant_user_edit_role', {tenantId: tenantId, id: user.id}) }}" class="d-flex align-items-center gap-2">
                            <label for="competencia" class="mb-0 small text-muted">Mês</label>
                            <select id="competencia" name="competencia" class="form-select form-select-sm" onchange="this.form.submit()" {% if competenciasPonto is empty %}disabled{% endif %}>
                                {% for competencia in competenciasPonto %}
                                    <option value="{{ competencia.valor }}" {% if competencia.valor == competenciaSelecionada %}selected{% endif %}>{{ competencia.label }}</option>
                                {% endfor %}
                            </select>
                        </form>
                    </div>
                    <div class="card-body p-0">
                        {% if competenciasPonto is empty %}
                            <p class="text-muted small p-3 mb-0">Este usuário ainda não possui registros de ponto.</p>
                        {% elseif batidasPonto is empty %}
                            <p class="text-muted small p-3 mb-0">Não há batidas para a competência selecionada.</p>
                        {% else %}
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Data</th>
                                        <th>Hora</th>
                                        <th>Tipo</th>
                                        <th>Sede</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% set tipoLabels = {'entrada': 'Entrada', 'repouso': 'Repouso', 'retorno': 'Retorno', 'saida': 'Saída'} %}
                                    {% set badgeClass = {'entrada': 'success', 'repouso': 'secondary', 'retorno': 'info', 'saida': 'warning'} %}
                                    {% for batida in batidasPonto %}
                                        <tr>
                                            <td class="align-middle">{{ batida.dataHora|date('d/m/Y') }}</td>
                                            <td class="align-middle">{{ batida.dataHora|date('H:i:s') }}</td>
                                            <td class="align-middle">
                                                <span class="badge bg-{{ badgeClass[batida.tipo] ?? 'dark' }}">{{ tipoLabels[batida.tipo] ?? batida.tipo }}</span>
                                            </td>
                                            <td class="align-middle">{{ batida.sede ? batida.sede.nome : (batida.sedeNomeSnapshot ?: 'N/A') }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        {% endif %}
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>
{% endblock %}
