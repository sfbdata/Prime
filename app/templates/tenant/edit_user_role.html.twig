{% extends 'base.html.twig' %}

{% block title %}Editar Roles{% endblock %}

{% block body %}
<div class="tenant-container">
    <h2 class="page-title">Editar Roles de {{ user.fullName }}</h2>

    {{ form_start(form) }}
        <div class="roles-list">
            {% for child in form.roles %}
                <div class="form-check mb-2">
                    {{ form_widget(child, {'attr': {'class': 'form-check-input'}}) }}
                    {{ form_label(child, null, {'label_attr': {'class': 'form-check-label'}}) }}
                </div>
            {% endfor %}
        </div>

        <hr class="my-4">

        <h5>Alterar senha (opcional)</h5>
        <p class="text-muted">Preencha os dois campos somente se desejar alterar a senha deste usuário.</p>

        <div class="mb-3">
            {{ form_label(form.newPassword.first, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.newPassword.first, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.newPassword.first) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.newPassword.second, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.newPassword.second, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.newPassword.second) }}
        </div>

        {{ form_errors(form.newPassword) }}

        <button class="btn btn-primary mt-3">Salvar</button>
    {{ form_end(form) }}

    <div class="mt-3">
        <a href="{{ path('app_tenant_users', {id: user.tenant.id}) }}" class="btn btn-secondary">Voltar</a>
    </div>
</div>
{% endblock %}
