{% extends 'base.html.twig' %}

{% block title %}Funcionários{% endblock %}

{% block body %}
<section class="content-header">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <h1 class="m-0">Funcionários - {{ tenant.name }}</h1>
        <a href="{{ path('app_tenant_show', {id: tenant.id}) }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i> Voltar
        </a>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-body table-responsive p-0">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th><i class="bi bi-person me-1"></i> Nome</th>
                            <th><i class="bi bi-envelope me-1"></i> Email</th>
                            <th><i class="bi bi-shield-check me-1"></i> Roles</th>
                            <th><i class="bi bi-calendar-plus me-1"></i> Criado em</th>
                            <th><i class="bi bi-gear me-1"></i> Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for user in users %}
                            <tr>
                                <td>{{ user.fullName }}</td>
                                <td>{{ user.email }}</td>
                                <td>
                                    {% for role in user.roles %}
                                        <span class="badge text-bg-secondary">{{ role }}</span>
                                    {% endfor %}
                                </td>
                                <td>{{ user.createdAt|date('d/m/Y H:i') }}</td>
                                <td>
                                    <a href="{{ path('app_tenant_user_edit_role', {tenantId: tenant.id, id: user.id}) }}"
                                       class="btn btn-sm btn-outline-primary"
                                       title="Editar roles do usuário"
                                       aria-label="Editar roles do usuário">
                                        <i class="bi bi-pencil me-1"></i> Editar Roles
                                    </a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center">Nenhum funcionário encontrado.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
{% endblock %}
