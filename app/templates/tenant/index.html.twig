{% extends 'base.html.twig' %}

{% block title %}Tenants{% endblock %}

{% block body %}
<section class="content-header">
    <div class="container-fluid">
        <h1 class="m-0">Meu Escritório</h1>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-body table-responsive p-0">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nome</th>
                            <th>Criado em</th>
                            <th>Status</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for tenant in tenants %}
                        <tr>
                            <td>{{ tenant.id }}</td>
                            <td>{{ tenant.name }}</td>
                            <td>{{ tenant.createdAt|date('d/m/Y H:i') }}</td>
                            <td>{{ tenant.isActive ? 'Ativo' : 'Inativo' }}</td>
                            <td>
                                {% if can_administer('admin.tenant.settings.manage') and app.user.tenant.id == tenant.id %}
                                    <a href="{{ path('app_tenant_edit', {'id': tenant.id}) }}"
                                       class="btn-action btn-action-edit"
                                       title="Editar escritório"
                                       aria-label="Editar escritório">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                {% else %}
                                    <span class="text-muted">Sem permissões</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
{% endblock %}
