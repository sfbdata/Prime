{% extends 'base.html.twig' %}

{% block title %}Novo Tenant{% endblock %}

{% block body %}
<div class="login-wrapper">
    <div class="login-container">
        <h1>Criar novo escritório</h1>

        {{ form_start(form) }}

        <div class="mb-3">
            {{ form_label(form.name, 'Nome do Escritório', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.name) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.adminEmail, 'Email do Administrador', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.adminEmail, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.adminEmail) }}
        </div>

        <button class="btn-login" type="submit">Criar Escritório</button>
        <div class="extra-links mt-3">
            <a href="{{ path('app_tenant_index') }}">Voltar</a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
