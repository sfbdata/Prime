{% extends 'base.html.twig' %}

{% block title %}Meu Escritório{% endblock %}

{% block body %}
<section class="content-header">
    <div class="container-fluid">
        <h1 class="m-0"><i class="bi bi-building me-2"></i>Meu Escritório</h1>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8">
                <div class="card card-outline card-primary">
                    <div class="card-header">
                        <h3 class="card-title"><i class="bi bi-info-circle me-2"></i>Informações do Escritório</h3>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-striped mb-0">
                            <tbody>
                                <tr><th style="width:40%"><i class="bi bi-hash me-1"></i>ID</th><td>{{ tenant.id }}</td></tr>
                                <tr><th><i class="bi bi-building me-1"></i>Nome</th><td>{{ tenant.name }}</td></tr>
                                <tr><th><i class="bi bi-calendar-event me-1"></i>Criado em</th><td>{{ tenant.createdAt ? tenant.createdAt|date('d/m/Y H:i:s') : '-' }}</td></tr>
                                <tr><th><i class="bi bi-toggle-on me-1"></i>Status</th><td>
                                    {% if tenant.isActive %}
                                        <span class="badge text-bg-success">Ativo</span>
                                    {% else %}
                                        <span class="badge text-bg-secondary">Inativo</span>
                                    {% endif %}
                                </td></tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="card-footer">
                        <div class="d-flex gap-2 justify-content-end">
                            {% if 'ROLE_SUPER_ADMIN' in app.user.roles %}
                                <a href="{{ path('app_tenant_index') }}" class="btn btn-secondary">
                                    <i class="bi bi-arrow-left me-1"></i>Voltar
                                </a>
                            {% endif %}
                            {% if 'ROLE_SUPER_ADMIN' in app.user.roles or ( 'ROLE_ADMIN' in app.user.roles and app.user.tenant.id == tenant.id ) %}
                                <a href="{{ path('app_tenant_edit', {'id': tenant.id}) }}" class="btn btn-primary">
                                    <i class="bi bi-pencil me-1"></i>Editar
                                </a>
                            {% endif %}
                            {% if 'ROLE_SUPER_ADMIN' in app.user.roles %}
                                {{ include('tenant/_delete_form.html.twig') }}
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
