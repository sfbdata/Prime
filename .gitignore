# Docker volumes e logs
/db_data/
/*.log

# Configurações de IDE
/.idea/
/.vscode/

# Histórico e cache locais
.bash_history
.composer/

# Dependências (instaladas via composer)
/vendor/
/app/vendor/

# Arquivos de ambiente com credenciais
/app/.env
.env.local
.env.*.local
.env.prod

